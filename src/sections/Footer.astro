---
import Button from "../components/Button.astro";
import Container from "../components/Container.astro";
---

<footer id="matter-container">
  <Container>
    <div class="footer-content">
      <div class="h2">State of the Open Home 2026</div>
      <div class="footer-subtitle">
        An event organized by the Open Home Foundation
      </div>
      <Button href="/" class="button button--primary">
        Tickets coming soon
      </Button>
      <div class="footer-content-bottom">
        <a href="#">Help & support</a>
        <span>Copyright @ Open Home Foundation</span>
      </div>
    </div>
    <div class="footer-nav">
      <div class="footer-nav-column">
        <div class="footer-nav-title">Home</div>
        <div class="footer-nav-items">
          <a class="footer-nav-item" href="#">What is State of the Open Home?</a
          >
          <a class="footer-nav-item" href="#">Why we're building in the open</a>
          <a class="footer-nav-item" href="#">Be part of the conversation</a>
        </div>
      </div>
      <div class="footer-nav-column">
        <div class="footer-nav-title">Conference</div>
        <div class="footer-nav-items">
          <a class="footer-nav-item" href="#">Speakers</a>
          <a class="footer-nav-item" href="#">Agenda</a>
        </div>
      </div>
      <div class="footer-nav-column">
        <div class="footer-nav-title">Resources</div>
        <div class="footer-nav-items">
          <a class="footer-nav-item" href="#">The venue</a>
          <a class="footer-nav-item" href="#">FAQ</a>
          <a class="footer-nav-item" href="#">Accessibility guide</a>
        </div>
      </div>
      <div class="footer-nav-column">
        <div class="footer-nav-title">Legal</div>
        <div class="footer-nav-items">
          <a class="footer-nav-item" href="#">Privacy</a>
          <a class="footer-nav-item" href="#">Terms of use</a>
        </div>
      </div>
      <div class="footer-nav-column">
        <div class="footer-nav-title">Social</div>
        <div class="footer-nav-items">
          <a class="footer-nav-item" href="#">Discord</a>
          <a class="footer-nav-item" href="#">Mastodon</a>
          <a class="footer-nav-item" href="#">Bluesky</a>
          <a class="footer-nav-item" href="#">Instagram</a>
          <a class="footer-nav-item" href="#">Facebook</a>
        </div>
      </div>
    </div>
  </Container>
</footer>

<style lang="scss">
  @use "../styles/mixins/breakpoint.scss" as *;

  footer {
    background-color: var(--ohf-dark-blue);
    //height: 580px;
    position: relative;
    display: flex;
    isolation: isolate;
    padding: 40px 24px 120px 24px;

    @include bp(desktop) {
      padding: 80px 80px 200px 80px;
    }

    :global(canvas) {
      z-index: -1;
    }

    :global(.container) {
      gap: 40px 96px;
    }

    .footer-nav {
      display: flex;
      gap: 20px 6px;
      flex-grow: 1;
      justify-content: space-between;
      flex-direction: column;

      @include bp(tablet) {
        flex-direction: row;
      }

      &-column {
        display: flex;
        flex-direction: column;
        gap: 6px;
      }

      &-title {
        font-family: var(--typography-heading-font-family);
        font-size: 12px;
        text-transform: uppercase;
      }

      &-items {
        display: flex;
        flex-direction: column;

        .footer-nav-item {
          color: #a2aab6;
          font-size: 12px;
          text-decoration: none;
          padding: 4px 0;
        }
      }
    }
  }
</style>
