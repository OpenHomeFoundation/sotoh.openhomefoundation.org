---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"button"> {
  email: string;
  label?: string;
}

const {
  email,
  label = "Help & support",
  class: className = "",
  ...attrs
} = Astro.props;
---

<button
  class={`copy-email ${className}`}
  data-email={email}
  type="button"
  aria-label={`${label} - click to copy email address`}
  {...attrs}
>
  <span class="copy-email__text">
    <span class="copy-email__default">{label}</span>
    <span class="copy-email__hover" aria-hidden="true">{label}</span>
  </span>
  <span class="copy-email__tooltip" aria-hidden="true">Email copied</span>
  <span class="copy-email__sr-status" role="status" aria-live="polite"></span>
</button>

<style lang="scss" is:global>
  .copy-email {
    display: inline-block;
    position: relative;
    text-decoration: none;
    color: #a2aab6;
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    cursor: pointer;
    text-align: left;
  }

  .copy-email__text {
    display: block;
    position: relative;
    overflow: hidden;
  }

  .copy-email__default,
  .copy-email__hover {
    display: block;
    padding: 2px 0;
    transition: transform 0.2s ease-out;
  }

  .copy-email__hover {
    position: absolute;
    top: 0;
    left: 0;
    transform: translateY(100%);
    color: #fff;
  }

  .copy-email__tooltip {
    position: absolute;
    bottom: 100%;
    left: 0;
    transform: translateY(4px);
    background: var(--sotoh-yellow);
    color: var(--ohf-dark-blue);
    padding: 6px 10px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 500;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.2s ease-out,
      transform 0.2s ease-out;
    z-index: 10;

    &::after {
      content: "";
      position: absolute;
      top: 100%;
      left: 12px;
      border: 5px solid transparent;
      border-top-color: var(--sotoh-yellow);
    }
  }

  .copy-email.is-copied .copy-email__tooltip {
    opacity: 1;
    transform: translateY(-4px);
  }

  .copy-email__sr-status {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .copy-email:hover .copy-email__text {
    .copy-email__default {
      transform: translateY(-100%);
    }

    .copy-email__hover {
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .copy-email__hover {
      display: none;
    }

    .copy-email__default,
    .copy-email__hover {
      transition: none;
    }

    .copy-email:hover .copy-email__text .copy-email__default {
      transform: none;
    }

    .copy-email__tooltip {
      transition: none;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", initCopyEmail);
  initCopyEmail();

  function initCopyEmail() {
    const copyButtons = document.querySelectorAll<HTMLButtonElement>(
      ".copy-email:not([data-copy-init])",
    );

    copyButtons.forEach((button) => {
      button.setAttribute("data-copy-init", "true");
      button.addEventListener("click", async () => {
        const email = button.dataset.email;
        if (!email) return;

        try {
          await navigator.clipboard.writeText(email);
          button.classList.add("is-copied");

          const status = button.querySelector(".copy-email__sr-status");
          if (status) status.textContent = `Copied ${email} to clipboard`;

          setTimeout(() => {
            button.classList.remove("is-copied");
            if (status) status.textContent = "";
          }, 2000);
        } catch (err) {
          // Fallback: show email in prompt if clipboard fails
          window.prompt("Copy this email address:", email);
        }
      });
    });
  }
</script>
