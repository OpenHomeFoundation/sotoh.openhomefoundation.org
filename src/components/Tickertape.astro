---
import { ICONS } from "../lib/icons";

interface Props {
  theme?: "blue" | "yellow" | "purple";
  class?: string;
  speed?: number;
  offset?: number;
}

const {
  theme = "blue",
  class: className = "",
  speed = 1,
  offset = 0,
} = Astro.props;
---

<div
  class={`tickertape tickertape--${theme} ${className}`}
  style={`--speed: ${speed}; --offset: ${offset};`}
>
  <div class="tickertape-track">
    <div class="tickertape-item">
      <Fragment set:html={ICONS["tickerTape"]} />
    </div>
    <div class="tickertape-item" aria-hidden="true">
      <Fragment set:html={ICONS["tickerTape"]} />
    </div>
    <div class="tickertape-item" aria-hidden="true">
      <Fragment set:html={ICONS["tickerTape"]} />
    </div>
    <div class="tickertape-item" aria-hidden="true">
      <Fragment set:html={ICONS["tickerTape"]} />
    </div>
  </div>
</div>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)"
  ).matches;

  if (!prefersReducedMotion) {
    document
      .querySelectorAll(".tickertape:not([data-initialized])")
      .forEach((tickertape) => {
        tickertape.setAttribute("data-initialized", "");

        ScrollTrigger.create({
          trigger: tickertape,
          start: "top bottom",
          end: "bottom top",
          onEnter: () => tickertape.classList.add("is-visible"),
          onLeave: () => tickertape.classList.remove("is-visible"),
          onEnterBack: () => tickertape.classList.add("is-visible"),
          onLeaveBack: () => tickertape.classList.remove("is-visible"),
        });
      });
  }
</script>

<style lang="scss">
  @keyframes tickertape-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-25%);
    }
  }

  .tickertape {
    --text-color: var(--text-on-dark);
    --background-color: var(--sotoh-blue);
    --overhang: 3.75rem;
    --max-width: 1600px;
    --speed: 1;
    --offset: 0;
    --duration: calc(15s / var(--speed));

    &--blue {
      transform: scale(0.8);
    }

    &--yellow {
      --background-color: var(--sotoh-yellow);
      --text-color: var(--text-on-light);
    }

    &--purple {
      --background-color: var(--sotoh-purple);
    }

    width: calc(100% + var(--overhang) * 2);
    max-width: var(--max-width);
    margin-inline: auto;
    background-color: var(--background-color);
    overflow: hidden;
    position: relative;

    @media (max-width: 1700px) {
      margin-inline: calc(var(--overhang) * -1);
      border-radius: 0;
    }

    :global(svg) {
      color: var(--text-color);
    }

    &.full-width {
      width: 100%;
      max-width: 100%;
      margin-inline: 0;
    }
  }

  .tickertape-track {
    display: flex;
    flex-direction: row;
    width: fit-content;
    will-change: transform;
    animation: tickertape-scroll var(--duration) linear infinite;
    animation-play-state: paused;
    animation-delay: calc(var(--offset) * var(--duration) * -1);

    .tickertape.is-visible & {
      animation-play-state: running;
    }

    @media (prefers-reduced-motion: reduce) {
      animation: none;
    }
  }

  .tickertape-item {
    flex-shrink: 0;

    :global(svg) {
      display: block;
    }
  }
</style>
