---
// Import global styles
import "../styles/_variables.scss";
import "../styles/_reset.scss";
import "../styles/_global.scss";
import "../styles/_typography.scss";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>SOTOH</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&family=Special+Gothic+Expanded+One&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot name="header" />
    <div id="smooth-wrapper">
      <div id="smooth-content">
        <slot />
      </div>
    </div>

    <div class="noise"></div>
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
  }

  #smooth-content {
    padding-top: var(--header-height);
  }

  .noise {
    position: fixed;
    left: 0;
    top: 0;
    width: 100vw;
    height: 100vh;
    z-index: 110;
    pointer-events: none;
  }

  .noise:before {
    content: "";
    width: 200vw;
    height: 200vh;
    background-image: url(/src/images/noise.webp);
    background-repeat: repeat;
    position: absolute;
    left: -50vw;
    top: -50vh;
    z-index: 2;
    opacity: 0.15;
    animation: noiseMoving 0.2s infinite steps(1);
  }

  @keyframes noiseMoving {
    0% {
      transform: translate(0);
    }

    10% {
      transform: translate(-10vw, -10vh);
    }

    20% {
      transform: translate(8vw, 12vh);
    }

    30% {
      transform: translate(-12vw, 6vh);
    }

    40% {
      transform: translate(10vw, -8vh);
    }

    50% {
      transform: translate(-6vw, 14vh);
    }

    60% {
      transform: translate(14vw, -12vh);
    }

    70% {
      transform: translate(-8vw, 10vh);
    }

    80% {
      transform: translate(12vw, -6vh);
    }

    90% {
      transform: translate(-10vw, 8vh);
    }

    to {
      transform: translate(0);
    }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { ScrollSmoother } from "gsap/ScrollSmoother";

  gsap.registerPlugin(ScrollTrigger, ScrollSmoother);

  const mm = gsap.matchMedia();

  mm.add(
    {
      reduceMotion: "(prefers-reduced-motion: reduce)",
      normal: "(prefers-reduced-motion: no-preference)",
    },
    (context) => {
      const { reduceMotion } = context.conditions!;

      if (!reduceMotion) {
        ScrollSmoother.create({
          smooth: 1,
          effects: true,
        });
      }

      if (reduceMotion) {
        gsap.defaults({ duration: 0 });
      }
    }
  );

  import { initMatter } from "../lib/matter";
  const siteFooter = document.querySelector("#matter-container");
  if (siteFooter) {
    ScrollTrigger.create({
      trigger: siteFooter,
      start: "top bottom",
      once: true,
      onEnter: () => {
        initMatter();
      },
    });
  }
</script>
