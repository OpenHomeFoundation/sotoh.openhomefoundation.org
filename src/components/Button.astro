---
import { ICONS, type ICON } from "../lib/icons";

interface Props {
  class?: string;
  href?: string;
  icon?: ICON;
}
const { class: className = "", href = "/error", icon } = Astro.props;
---

<a class={className} href={href}>
  {
    icon ? (
      <div class="button-icon">
        <Fragment set:html={ICONS[icon]} />
      </div>
    ) : null
  }
  <span class="button-text">
    <span class="button-text__default"><slot /></span>
    <span class="button-text__hover" aria-hidden="true"><slot /></span>
  </span>
  <!-- Top bursts -->
  <span
    class="burst"
    style="--angle: -45deg; --size: 14px; --delay: 0ms; --distance: 50px; --start-x: 15%; --color: var(--sotoh-yellow);"
    aria-hidden="true"
  >
    <Fragment set:html={ICONS["building"]} />
  </span>
  <span
    class="burst"
    style="--angle: -10deg; --size: 10px; --delay: 60ms; --distance: 38px; --start-x: 40%; --color: var(--sotoh-blue);"
    aria-hidden="true"
  >
    <Fragment set:html={ICONS["privacy"]} />
  </span>
  <span
    class="burst"
    style="--angle: 20deg; --size: 10px; --delay: 120ms; --distance: 32px; --start-x: 65%; --color: var(--sotoh-purple);"
    aria-hidden="true"
  >
    <Fragment set:html={ICONS["choice"]} />
  </span>
  <span
    class="burst"
    style="--angle: 50deg; --size: 8px; --delay: 180ms; --distance: 50px; --start-x: 85%; --color: var(--sotoh-yellow);"
    aria-hidden="true"
  >
    <Fragment set:html={ICONS["sustainability"]} />
  </span>
  <!-- Bottom bursts -->
  <span
    class="burst"
    style="--angle: 135deg; --size: 10px; --delay: 90ms; --distance: 50px; --start-x: 75%; --color: var(--sotoh-blue);"
    aria-hidden="true"
  >
    <Fragment set:html={ICONS["building"]} />
  </span>
  <span
    class="burst"
    style="--angle: 170deg; --size: 8px; --delay: 150ms; --distance: 45px; --start-x: 45%; --color: var(--sotoh-purple);"
    aria-hidden="true"
  >
    <Fragment set:html={ICONS["choice"]} />
  </span>
  <span
    class="burst"
    style="--angle: -140deg; --size: 12px; --delay: 30ms; --distance: 40px; --start-x: 25%; --color: var(--sotoh-yellow);"
    aria-hidden="true"
  >
    <Fragment set:html={ICONS["privacy"]} />
  </span>
</a>

<style lang="scss" is:global>
  @use "../styles/mixins/breakpoint.scss" as *;

  .button {
    position: relative;
    overflow: visible;
    color: var(--text-on-dark);
    padding: 8px 12px;
    border-radius: 40px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-family: var(--typography-heading-font-family);
    font-weight: var(--typography-heading-font-weight);
    font-size: 0.75rem;
    gap: 12px;
    text-transform: uppercase;

    @include bp(large-mobile) {
      padding: 12px 24px;
    }

    &:has(.button-icon) {
      padding: 0.5rem 1.5rem 0.5rem 0.5rem;
    }

    &-icon {
      display: grid;
      place-items: center;
      background-color: white;
      height: 24px;
      width: 24px;
      border-radius: 50%;
    }

    &--hollow {
      border: 2px solid var(--sotoh-yellow);
    }

    &-text {
      display: block;
      position: relative;
      overflow: hidden;

      &__default,
      &__hover {
        display: block;
        transition: transform 0.3s ease-in-out;
      }

      &__default {
        transition: color 0.3s ease-in-out;
      }

      &__hover {
        position: absolute;
        top: 0;
        left: 0;
        transform: translateY(100%);
      }

      @media (prefers-reduced-motion: reduce) {
        &__hover {
          display: none;
        }

        &__default,
        &__hover {
          transition: none;
        }
      }
    }

    &:hover &-text {
      &__default {
        transform: translateY(-100%);
      }

      &__hover {
        transform: translateY(0);
      }

      @media (prefers-reduced-motion: reduce) {
        &__default {
          transform: none;
        }
      }
    }

    &--primary {
      background-color: var(--sotoh-yellow);
      color: var(--ohf-dark-blue);
      transition: background-color 0.3s ease-in-out;

      .button-text__hover {
        color: var(--sotoh-yellow);
      }

      &:hover {
        background-color: var(--ohf-dark-blue);

        @media (prefers-reduced-motion: reduce) {
          .button-text__default {
            color: var(--sotoh-yellow);
          }
        }
      }
    }

    // Burst effect - Option 4: rotate + translate
    .burst {
      --angle: 0deg;
      --size: 12px;
      --distance: 60px;
      --delay: 0ms;
      --start-x: 50%;
      --color: var(--sotoh-yellow);

      position: absolute;
      top: 50%;
      left: var(--start-x);
      width: var(--size);
      height: var(--size);
      pointer-events: none;
      z-index: -1;

      // Start: centered, rotated to angle, no outward movement, scaled down
      transform: translate(-50%, -50%) rotate(var(--angle)) translateY(0)
        scale(0);
      opacity: 0;
      transition:
        transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) var(--delay),
        opacity 0.25s ease var(--delay);

      svg {
        display: block;
        width: 100%;
        height: 100%;
        color: var(--color);
      }
    }

    &:hover .burst {
      // End: translate outward along rotated axis, scale up
      transform: translate(-50%, -50%) rotate(var(--angle))
        translateY(calc(var(--distance) * -1)) scale(1);
      opacity: 1;
    }

    @media (prefers-reduced-motion: reduce) {
      .burst {
        display: none;
      }
    }
  }
</style>
