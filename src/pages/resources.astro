---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Countdown from "../components/Countdown.astro";
import Building from "../sections/Building.astro";
import TickertapeGroup from "../components/TickertapeGroup.astro";
import WhatIs from "../sections/WhatIs.astro";
import Carousel from "../components/Carousel.astro";
import Why from "../sections/Why.astro";
import Tickertape from "../components/Tickertape.astro";
import BePart from "../sections/BePart.astro";
import Footer from "../sections/Footer.astro";
import Tivolivredenburg from "../sections/Tivolivredenburg.astro";
---

<Layout>
  <Header slot="header" />
  <section class="block block-hero">
    <Hero />
  </section>
  <section class="block block-be-part" id="be-part-of-the-conversation">
    <Tivolivredenburg />
  </section>
  <section class="block block-tickertape">
    <Tickertape theme="yellow" class="full-width" fullWidth={true} />
  </section>
  <Footer />
</Layout>

<style lang="scss">
  .block {
    &-hero {
      margin-bottom: 2rem;
    }

    &-countdown {
      margin-bottom: 6rem;
    }

    &-tickertape-group {
      overflow: hidden;
    }

    &-image-carousel {
      padding-top: 5rem;
    }

    &-what-is,
    &-image-carousel,
    &-why {
      margin-bottom: 5rem;
    }
  }
</style>
