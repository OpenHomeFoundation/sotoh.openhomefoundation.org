---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Tickertape from "../components/Tickertape.astro";
import Footer from "../sections/Footer.astro";
import Tivolivredenburg from "../sections/Tivolivredenburg.astro";
import EventFAQ from "../sections/EventFAQ.astro";
import Tabs from "../components/Tabs.astro";
import Tab from "../components/Tab.astro";
import TicketInclusionsFAQ from "../sections/TicketInclusionsFAQ.astro";
import GettingThere from "../sections/GettingThere.astro";
import Container from "../components/Container.astro";
---

<Layout bodyClass="page-resources">
  <Header slot="header" lightMode />
  <section class="block block-be-part">
    <Tivolivredenburg />
  </section>
  <section class="block block-getting-there">
    <GettingThere />
  </section>
  <section class="block block-tickertape">
    <Tickertape theme="yellow" class="full-width" fullWidth={true} />
  </section>
  <Footer />

  <style lang="scss">
    .block {
      &-getting-there {
        padding: 4.5rem 0;
      }

      &-event-faq {
        padding: 0 0 4.5rem;

        .h2 {
          margin-bottom: 4rem;
        }
      }
    }
  </style>
</Layout>
