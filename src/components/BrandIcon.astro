---
import { BRAND_ICONS, type BRAND_ICON } from "../lib/brand-icons";

interface Props {
  icon: BRAND_ICON;
  class?: string;
  duration?: number;
}

const { icon, class: className = "", duration } = Astro.props;
const iconData = BRAND_ICONS[icon];
const style = duration ? `--brand-icon-duration: ${duration}ms` : undefined;
---

<div class:list={["brand-icon", `brand-icon--${icon}`, className]} style={style}>
  <Fragment set:html={iconData.svg} />
</div>

<style lang="scss" is:global>
  .brand-icon {
    display: block;
    pointer-events: all;

    svg {
      display: block;
      width: 100%;
      height: 100%;
    }

  }

  // ============================================
  // Building icon animations (5s cycle, plays in first 30%)
  // ============================================
  .brand-icon--building {
    $timing: linear;

    @keyframes building-corner-move {
      0% {
        transform: translate(225px, 225px);
        animation-timing-function: cubic-bezier(0.9, 0, 0.1, 1);
      }
      12.68% {
        transform: translate(112.5px, 112.5px);
        animation-timing-function: cubic-bezier(0.9, 0, 0.1, 1);
      }
      25.36%, 100% {
        transform: translate(0px, 0px);
      }
    }

    @keyframes building-side-move {
      0% {
        transform: translate(113px, 113px);
        animation-timing-function: cubic-bezier(0.9, 0, 0.1, 1);
      }
      12.68% {
        transform: translate(0.32px, 113px);
        animation-timing-function: cubic-bezier(0.9, 0, 0.1, 1);
      }
      25.36%, 100% {
        transform: translate(-112.36px, 113px);
      }
    }

    @keyframes building-fade-corner {
      0%, 12% {
        opacity: 0;
      }
      12.25%, 100% {
        opacity: 0.86;
      }
    }

    @keyframes building-fade-side {
      0%, 12.43% {
        opacity: 0;
      }
      12.68%, 100% {
        opacity: 0.8634;
      }
    }

    @keyframes building-center-scale {
      0% {
        transform: translate(225px, 225px) scale(0.25, 0.25);
        animation-timing-function: cubic-bezier(0.9, 0, 0.1, 1);
      }
      12.68% {
        transform: translate(225px, 225px) scale(0.5, 0.5);
        animation-timing-function: cubic-bezier(0.9, 0, 0.1, 1);
      }
      25.36%, 100% {
        transform: translate(225px, 225px) scale(0.25, 0.25);
      }
    }

    #building-anim-1,
    #building-anim-2,
    #building-anim-3,
    #building-anim-4,
    #building-anim-5,
    #building-anim-6,
    #building-anim-7,
    #building-anim-8 {
      animation: building-corner-move var(--brand-icon-duration, 6000ms) $timing 1s infinite normal forwards;
    }

    #building-anim-9,
    #building-anim-10,
    #building-anim-11,
    #building-anim-12,
    #building-anim-13,
    #building-anim-14,
    #building-anim-15,
    #building-anim-16 {
      animation: building-side-move var(--brand-icon-duration, 6000ms) $timing 1s infinite normal forwards;
    }

    #building-fade-1,
    #building-fade-2,
    #building-fade-3,
    #building-fade-4 {
      animation: building-fade-corner var(--brand-icon-duration, 6000ms) $timing 1s infinite normal forwards;
    }

    #building-fade-5,
    #building-fade-6,
    #building-fade-7,
    #building-fade-8 {
      animation: building-fade-side var(--brand-icon-duration, 6000ms) $timing 1s infinite normal forwards;
    }

    #building-anim-center {
      animation: building-center-scale var(--brand-icon-duration, 6000ms) $timing 1s infinite normal forwards;
    }
  }

  // ============================================
  // Choice icon animations (5s cycle, plays in first 30%)
  // ============================================
  .brand-icon--choice {
    $timing: linear;
    $easing: cubic-bezier(0.9, 0, 0.1, 0.995);

    @keyframes choice-center-scale {
      0% {
        transform: translate(225px, 225px) scale(1, 1);
        animation-timing-function: $easing;
      }
      3.67% {
        transform: translate(225px, 225px) scale(2, 2);
        animation-timing-function: $easing;
      }
      7.35% {
        transform: translate(225px, 225px) scale(2, 2);
        animation-timing-function: $easing;
      }
      11.02%, 100% {
        transform: translate(225px, 225px) scale(6.9, 6.9);
      }
    }

    @keyframes choice-corner-1 {
      0%, 11.02%, 14.69% {
        transform: translate(392.65px, 167.65px) scale(0, 0);
      }
      14.69% {
        animation-timing-function: $easing;
      }
      18.37%, 100% {
        transform: translate(392.65px, 167.65px) scale(1, 1);
      }
    }

    @keyframes choice-corner-2 {
      0%, 11.02% {
        transform: translate(167.65px, 167.65px) scale(0, 0);
      }
      11.02% {
        animation-timing-function: $easing;
      }
      14.69%, 100% {
        transform: translate(167.65px, 167.65px) scale(1, 1);
      }
    }

    @keyframes choice-corner-3 {
      0%, 11.02%, 22.65% {
        transform: translate(167.65px, 392.65px) scale(0, 0);
      }
      22.65% {
        animation-timing-function: $easing;
      }
      26.33%, 100% {
        transform: translate(167.65px, 392.65px) scale(1, 1);
      }
    }

    @keyframes choice-corner-4 {
      0%, 11.02%, 18.37% {
        transform: translate(392.65px, 392.65px) scale(0, 0);
      }
      18.37% {
        animation-timing-function: $easing;
      }
      22.04%, 100% {
        transform: translate(392.65px, 392.65px) scale(1, 1);
      }
    }

    #choice-center {
      animation: choice-center-scale var(--brand-icon-duration, 6000ms) $timing 1s infinite normal forwards;
    }

    #choice-corner-1 {
      animation: choice-corner-1 var(--brand-icon-duration, 6000ms) $timing 1s infinite normal forwards;
    }

    #choice-corner-2 {
      animation: choice-corner-2 var(--brand-icon-duration, 6000ms) $timing 1s infinite normal forwards;
    }

    #choice-corner-3 {
      animation: choice-corner-3 var(--brand-icon-duration, 6000ms) $timing 1s infinite normal forwards;
    }

    #choice-corner-4 {
      animation: choice-corner-4 var(--brand-icon-duration, 6000ms) $timing 1s infinite normal forwards;
    }
  }

  // ============================================
  // Sustainability icon animations (5s cycle, plays in first 30%)
  // ============================================
  .brand-icon--sustainability {
    $timing: linear;
    $easing: cubic-bezier(0.9, 0, 0.1, 1);

    @keyframes sustainability-leaf-diagonal {
      0% {
        transform: translate(513.613px, 513.613px);
        animation-timing-function: $easing;
      }
      20%, 100% {
        transform: translate(288px, 288px);
      }
    }

    @keyframes sustainability-leaf-3-move {
      0% {
        transform: translate(225px, 225px);
        animation-timing-function: $easing;
      }
      20%, 100% {
        transform: translate(225.806px, 0.138px);
      }
    }

    @keyframes sustainability-leaf-4-move {
      0% {
        transform: translate(225px, 225px);
        animation-timing-function: $easing;
      }
      20%, 100% {
        transform: translate(225px, 0.138px);
      }
    }

    @keyframes sustainability-leaf-5-move {
      0% {
        transform: translate(225px, 225px);
        animation-timing-function: $easing;
      }
      20%, 100% {
        transform: translate(225px, 56.25px);
      }
    }

    @keyframes sustainability-leaf-5-scale {
      0% {
        transform: scale(1, 1);
        animation-timing-function: $easing;
      }
      20%, 100% {
        transform: scale(0.25, 0.25);
      }
    }

    #sustainability-leaf-1,
    #sustainability-leaf-2 {
      animation: sustainability-leaf-diagonal var(--brand-icon-duration, 6000ms) $timing 1s infinite normal forwards;
    }

    #sustainability-leaf-3 {
      animation: sustainability-leaf-3-move var(--brand-icon-duration, 6000ms) $timing 1s infinite normal forwards;
    }

    #sustainability-leaf-4 {
      animation: sustainability-leaf-4-move var(--brand-icon-duration, 6000ms) $timing 1s infinite normal forwards;
    }

    #sustainability-leaf-5-wrap,
    #sustainability-leaf-6-wrap {
      animation: sustainability-leaf-5-move var(--brand-icon-duration, 6000ms) $timing 1s infinite normal forwards;
    }

    #sustainability-leaf-5,
    #sustainability-leaf-6 {
      animation: sustainability-leaf-5-scale var(--brand-icon-duration, 6000ms) $timing 1s infinite normal forwards;
    }
  }

  // ============================================
  // Privacy icon animations (5s cycle, plays in first 30%)
  // ============================================
  .brand-icon--privacy {
    $timing: linear;
    $easing: cubic-bezier(0.9, 0, 0.1, 0.995);

    @keyframes privacy-scale {
      0% {
        transform: translate(288px, 288px) scale(1, 1);
        animation-timing-function: $easing;
      }
      4.87% {
        transform: translate(288px, 288px) scale(5, 5);
      }
      5.68%, 100% {
        transform: translate(288px, 288px) scale(1, 1);
      }
    }

    @keyframes privacy-quad-1 {
      0%, 4.87% {
        transform: translate(225px, 225px);
      }
      5.68% {
        transform: translate(97.71px, 352.29px);
        animation-timing-function: $easing;
      }
      10.54%, 100% {
        transform: translate(225px, 225px);
      }
    }

    @keyframes privacy-quad-2 {
      0%, 4.87% {
        transform: translate(225px, 225px);
      }
      5.68% {
        transform: translate(351.71px, 351.71px);
        animation-timing-function: $easing;
      }
      20.27% {
        transform: translate(351.71px, 351.71px);
        animation-timing-function: $easing;
      }
      25.13%, 100% {
        transform: translate(225px, 225px);
      }
    }

    @keyframes privacy-quad-3 {
      0%, 4.87% {
        transform: translate(225px, 225px);
      }
      5.68% {
        transform: translate(351.71px, 98.29px);
        animation-timing-function: $easing;
      }
      15.41% {
        transform: translate(351.71px, 98.29px);
        animation-timing-function: $easing;
      }
      20.27%, 100% {
        transform: translate(225px, 225px);
      }
    }

    @keyframes privacy-quad-4 {
      0%, 4.87% {
        transform: translate(225px, 225px);
      }
      5.68% {
        transform: translate(97.14px, 97.14px);
        animation-timing-function: $easing;
      }
      10.54% {
        transform: translate(97.14px, 97.14px);
        animation-timing-function: $easing;
      }
      15.41%, 100% {
        transform: translate(225px, 225px);
      }
    }

    #privacy-scale {
      animation: privacy-scale var(--brand-icon-duration, 6000ms) $timing 1s infinite normal forwards;
    }

    #privacy-quad-1 {
      animation: privacy-quad-1 var(--brand-icon-duration, 6000ms) $timing 1s infinite normal forwards;
    }

    #privacy-quad-2 {
      animation: privacy-quad-2 var(--brand-icon-duration, 6000ms) $timing 1s infinite normal forwards;
    }

    #privacy-quad-3 {
      animation: privacy-quad-3 var(--brand-icon-duration, 6000ms) $timing 1s infinite normal forwards;
    }

    #privacy-quad-4 {
      animation: privacy-quad-4 var(--brand-icon-duration, 6000ms) $timing 1s infinite normal forwards;
    }
  }
</style>
