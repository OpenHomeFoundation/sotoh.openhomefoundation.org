---
import { ICONS, type ICON } from "../lib/icons";

interface Props {
  class?: string;
  href?: string;
  icon?: ICON;
  disabled?: boolean;
  target?: string;
  starburst?: boolean;
}
const {
  class: className = "",
  href = "/error",
  icon,
  disabled = false,
  target = "_self",
  starburst = false,
} = Astro.props;
---

<a class={className} href={href} aria-disabled={disabled} target={target}>
  {
    icon ? (
      <div class="button-icon">
        <Fragment set:html={ICONS[icon]} />
      </div>
    ) : null
  }
  <span class="button-text">
    <span class="button-text__default"><slot /></span>
    <span class="button-text__hover" aria-hidden="true"><slot /></span>
  </span>
  {
    starburst && (
      <>
        <span
          class="burst"
          style="--angle: -50deg; --size: 13px; --delay: 0ms; --distance: 48px; --start-x: 5%; --color: var(--sotoh-yellow);"
          aria-hidden="true"
        >
          <Fragment set:html={ICONS["building"]} />
        </span>
        <span
          class="burst"
          style="--angle: -25deg; --size: 10px; --delay: 80ms; --distance: 36px; --start-x: 28%; --color: var(--sotoh-blue);"
          aria-hidden="true"
        >
          <Fragment set:html={ICONS["privacy"]} />
        </span>
        <span
          class="burst"
          style="--angle: 5deg; --size: 11px; --delay: 40ms; --distance: 42px; --start-x: 47%; --color: var(--sotoh-purple);"
          aria-hidden="true"
        >
          <Fragment set:html={ICONS["sustainability"]} />
        </span>
        <span
          class="burst"
          style="--angle: 30deg; --size: 9px; --delay: 140ms; --distance: 37px; --start-x: 68%; --color: var(--sotoh-yellow);"
          aria-hidden="true"
        >
          <Fragment set:html={ICONS["choice"]} />
        </span>
        <span
          class="burst"
          style="--angle: 55deg; --size: 12px; --delay: 200ms; --distance: 52px; --start-x: 88%; --color: var(--sotoh-blue);"
          aria-hidden="true"
        >
          <Fragment set:html={ICONS["building"]} />
        </span>
        <span
          class="burst"
          style="--angle: 125deg; --size: 10px; --delay: 100ms; --distance: 50px; --start-x: 82%; --color: var(--sotoh-purple);"
          aria-hidden="true"
        >
          <Fragment set:html={ICONS["privacy"]} />
        </span>
        <span
          class="burst"
          style="--angle: 160deg; --size: 8px; --delay: 160ms; --distance: 40px; --start-x: 38%; --color: var(--sotoh-yellow);"
          aria-hidden="true"
        >
          <Fragment set:html={ICONS["choice"]} />
        </span>
        <span
          class="burst"
          style="--angle: -135deg; --size: 11px; --delay: 60ms; --distance: 44px; --start-x: 12%; --color: var(--sotoh-blue);"
          aria-hidden="true"
        >
          <Fragment set:html={ICONS["sustainability"]} />
        </span>
      </>
    )
  }
</a>

<style lang="scss" is:global>
  @use "../styles/mixins/breakpoint.scss" as *;

  .button {
    position: relative;
    overflow: visible;
    color: var(--text-on-dark);
    padding: 8px 10px;
    border-radius: 40px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-family: var(--typography-heading-font-family);
    font-weight: var(--typography-heading-font-weight);
    font-size: 0.75rem;
    gap: 12px;
    text-transform: uppercase;

    @include bp(large-mobile) {
      padding: 12px 24px;
    }

    &[aria-disabled="true"] {
      pointer-events: none;
    }

    &:has(.button-icon) {
      padding: 0.5rem 1.5rem 0.5rem 0.5rem;
    }

    &-icon {
      display: grid;
      place-items: center;
      background-color: white;
      height: 24px;
      width: 24px;
      border-radius: 50%;
    }

    &--hollow {
      transition:
        background-color 0.3s ease-in-out,
        color 0.3s ease-in-out,
        border-color 0.3s ease-in-out;
      border: 2px solid var(--sotoh-yellow);

      &.button--secondary {
        border: 2px solid var(--ohf-dark-blue);
        color: var(--ohf-dark-blue);
      }
    }

    &-text {
      display: block;
      position: relative;
      overflow: hidden;

      &__default,
      &__hover {
        display: block;
        transition: transform 0.3s ease-in-out;
      }

      &__default {
        transition:
          color 0.3s ease-in-out,
          transform 0.3s ease-in-out;
      }

      &__hover {
        position: absolute;
        top: 0;
        left: 0;
        transform: translateY(100%);
      }

      @media (prefers-reduced-motion: reduce) {
        &__hover {
          display: none;
        }

        &__default,
        &__hover {
          transition: none;
        }
      }
    }

    &:hover &-text {
      &__default {
        transform: translateY(-100%);
      }

      &__hover {
        transform: translateY(0);
      }

      @media (prefers-reduced-motion: reduce) {
        &__default {
          transform: none;
        }
      }
    }

    &--primary {
      background-color: var(--sotoh-yellow);
      color: var(--ohf-dark-blue);
      transition: background-color 0.3s ease-in-out;

      .button-text__hover {
        color: var(--sotoh-yellow);
      }

      &:hover {
        background-color: var(--ohf-dark-blue);

        @media (prefers-reduced-motion: reduce) {
          .button-text__default {
            color: var(--sotoh-yellow);
          }
        }
      }

      &.button--primary-hover-light {
        .button-text__hover {
          color: var(--text-on-light);
        }

        &:hover {
          background-color: var(--text-on-dark);

          @media (prefers-reduced-motion: reduce) {
            .button-text__default {
              color: var(--text-on-light);
            }
          }
        }
      }
    }

    .burst {
      --angle: 0deg;
      --size: 12px;
      --distance: 60px;
      --delay: 0ms;
      --start-x: 50%;
      --color: var(--sotoh-yellow);

      position: absolute;
      top: 50%;
      left: var(--start-x);
      width: var(--size);
      height: var(--size);
      pointer-events: none;
      z-index: -1;

      transform: translate(-50%, -50%) rotate(var(--angle)) translateY(0)
        scale(0);
      opacity: 0;
      transition:
        transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) var(--delay),
        opacity 0.25s ease var(--delay);

      svg {
        display: block;
        width: 100%;
        height: 100%;
        color: var(--color);
      }
    }

    &:hover .burst {
      transform: translate(-50%, -50%) rotate(var(--angle))
        translateY(calc(var(--distance) * -1)) scale(1);
      opacity: 1;
    }

    @media (prefers-reduced-motion: reduce) {
      .burst {
        display: none;
      }
    }
  }
</style>
