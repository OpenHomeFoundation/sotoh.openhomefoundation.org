---
import { Image } from "astro:assets";

interface Props {
  firstName?: string;
  lastName?: string;
  role?: string;
  company?: string;
  image?: ImageMetadata;
  variant?: number;
  theme?: string;
}

const { firstName, lastName, role, company, image, variant, theme } =
  Astro.props;

const backgroundImage = variant
  ? `/images/speaker-cards/speaker-card-${variant}.webp`
  : "/images/speaker-cards/speaker-card-1.webp";
---

<div
  class={`speaker-card speaker-card--${theme}`}
  style={`background-image: url(${backgroundImage})`}
>
  <p class="speaker-card__name">
    <span class="first-name heading">{firstName}</span>
    <span class="last-name">{lastName}</span>
  </p>

  <div class="speaker-card__meta">
    <p class="speaker-card__role heading">{role}</p>
    <p class="speaker-card__company heading">{company}</p>
  </div>

  {
    image && (
      <Image
        src={image}
        alt={`A photo of ${firstName} ${lastName}`}
        widths={[]}
        sizes=""
        class="speaker-card__image"
        loading="lazy"
        decoding="async"
      />
    )
  }
</div>

<style lang="scss">
  @use "../styles/mixins/breakpoint.scss" as *;

  .speaker-card {
    --text-color: var(--text-on-dark);

    &--light {
      --text-color: var(--text-on-light);
    }

    position: relative;
    width: 100%;
    max-width: 208px;
    max-height: 366px;
    aspect-ratio: 1 / 2;
    background-size: cover;
    background-position: center;
    border-radius: 8px;
    color: var(--text-color);
    overflow: hidden;

    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;

    padding: 1.25rem;

    @include bp(tablet) {
      max-width: 291px;
      max-height: 560px;
      padding: 2rem 1.5rem;
    }

    &__image {
      width: 100%;
      height: 73%;
      position: absolute;
      bottom: 0;
      left: 0;
      object-fit: cover;
      object-position: center top;
      z-index: 0;

      @include bp(tablet) {
        height: 75%;
      }
    }

    p,
    .heading {
      color: var(--text-color);
      position: relative;
      z-index: 1;
      text-align: left;
    }

    &__name {
      width: 100%;
      display: flex;
      flex-direction: column;
      font-size: clamp(1rem, 0.912rem + 0.3756vw, 1.25rem);
      line-height: 1;
      margin-bottom: 0.75rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid var(--text-color);

      .first-name {
        text-transform: uppercase;
        font-weight: 600;
        font-size: clamp(1.25rem, 0.9859rem + 1.1268vw, 2rem);
        margin-bottom: 0;
      }
    }

    &__meta {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    &__role,
    &__company {
      font-size: 0.625rem;
      line-height: 1.2;
      text-wrap: unset;
      margin: 0;

      @include bp(tablet) {
        font-size: 0.75rem;
      }
    }
  }
</style>
