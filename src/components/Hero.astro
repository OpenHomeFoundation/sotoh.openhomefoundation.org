---
import Container from "../components/Container.astro";
import Content from "../components/Content.astro";

import { Image } from "astro:assets";

import { ICONS } from "../lib/icons";

import logoPlaceholder from "../images/logo-placeholder.png";
import BrandIcon from "./BrandIcon.astro";
---

<Container containerClass="container--hero">
  <p class="event-host p--large">
    An event organized by the <Fragment set:html={ICONS["OHFLogo"]} />
  </p>

  <div class="brand-icons">
    <BrandIcon icon="building" />
    <BrandIcon icon="privacy" />
    <BrandIcon icon="choice" />
    <BrandIcon icon="sustainability" />
  </div>

  <Content>
    <h1 class="h1">STATE OF THE OPEN HOME</h1>
    <ul class="event-details">
      <li>Wednesday, April 8, 2026</li>
      <li>Utrecht, The Netherlands</li>
      <li>Tickets available now!</li>
    </ul>
  </Content>
</Container>

<style lang="scss">
  @use "../styles/mixins/breakpoint.scss" as *;

  @keyframes animate-up-fade {
    0% {
      transform: translate3d(0, 50%, 0);
      opacity: 0;
    }
    100% {
      transform: none;
      opacity: 1;
    }
  }

  img {
    width: 100%;
    height: auto;
  }

  h1 {
    margin-bottom: 0;
    text-align: center;

    @media (prefers-reduced-motion: no-preference) {
      opacity: 0;
      animation-name: animate-up-fade;
      animation-fill-mode: forwards;
      animation-duration: 0.5s;
      animation-timing-function: var(--entry-ease);
      animation-delay: 0.65s;
    }
  }

  p.event-host {
    line-height: 1.4;
    margin-bottom: 0;

    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    gap: 0 0.6rem;
    flex-wrap: wrap;

    @media (prefers-reduced-motion: no-preference) {
      opacity: 0;
      animation-name: animate-up-fade;
      animation-fill-mode: forwards;
      animation-duration: 0.45s;
      animation-timing-function: var(--entry-ease);
      animation-delay: 0.55s;
    }

    :global(svg) {
      width: 100%;
      max-width: 350px;
      max-height: 34px;
    }
  }

  .event-details {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: clamp(1rem, 0.9886rem + 0.6818vw, 1.5rem);

    @media (prefers-reduced-motion: no-preference) {
      opacity: 0;
      animation-name: animate-up-fade;
      animation-fill-mode: forwards;
      animation-duration: 0.45s;
      animation-timing-function: var(--entry-ease);
      animation-delay: 0.85s;
    }

    @include bp(tablet) {
      flex-direction: row;
      gap: 1rem;
    }

    @include bp(desktop) {
      gap: 1.5rem;
    }

    li {
      flex-shrink: 0;

      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 0.625rem;

      @include bp(tablet) {
        gap: 1rem;
      }

      @include bp(desktop) {
        gap: 1.5rem;
      }

      &:last-child {
        &:after {
          content: none;
        }
      }

      &:after {
        width: 0.25rem;
        height: 0.25rem;
        content: "";
        display: inline-block;
        background-color: currentColor;
        border-radius: 50%;

        @include bp(tablet) {
          width: 0.5rem;
          height: 0.5rem;
        }
      }
    }
  }

  .brand-icons {
    // 2x2 on mobile, 4x1 on desktop
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat(2, auto);

    @media (prefers-reduced-motion: no-preference) {
      opacity: 0;
      animation-name: animate-up-fade;
      animation-fill-mode: forwards;
      animation-duration: 0.85s;
      animation-timing-function: var(--entry-ease);
    }

    @include bp(desktop) {
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: auto;
    }
  }
</style>
