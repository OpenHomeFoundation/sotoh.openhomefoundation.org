---
import {
  calculateCountdown,
  formatCountdownValue,
  TARGET_DATE,
} from "../lib/countdown";

const initial = calculateCountdown();
---

<div class="countdown" data-target={TARGET_DATE.toISOString()}>
  <div class="countdown-item">
    <span class="countdown-value" data-days
      >{formatCountdownValue(initial.days)}</span
    >
    <span class="countdown-label">Days</span>
  </div>
  <span class="countdown-separator">:</span>
  <div class="countdown-item">
    <span class="countdown-value" data-hours
      >{formatCountdownValue(initial.hours)}</span
    >
    <span class="countdown-label">Hours</span>
  </div>
  <span class="countdown-separator countdown-separator--hide-mobile">:</span>
  <div class="countdown-item">
    <span class="countdown-value" data-minutes
      >{formatCountdownValue(initial.minutes)}</span
    >
    <span class="countdown-label">Minutes</span>
  </div>
  <span class="countdown-separator">:</span>
  <div class="countdown-item">
    <span class="countdown-value" data-seconds
      >{formatCountdownValue(initial.seconds)}</span
    >
    <span class="countdown-label">Seconds</span>
  </div>
</div>

<script>
  import { calculateCountdown, formatCountdownValue } from "../lib/countdown";

  function initCountdown() {
    const countdownEl = document.querySelector(".countdown") as HTMLElement;
    if (!countdownEl) return;

    const targetDate = new Date(countdownEl.dataset.target || "");
    const daysEl = countdownEl.querySelector("[data-days]");
    const hoursEl = countdownEl.querySelector("[data-hours]");
    const minutesEl = countdownEl.querySelector("[data-minutes]");
    const secondsEl = countdownEl.querySelector("[data-seconds]");

    function update() {
      const { days, hours, minutes, seconds, isExpired } =
        calculateCountdown(targetDate);

      if (daysEl) daysEl.textContent = formatCountdownValue(days);
      if (hoursEl) hoursEl.textContent = formatCountdownValue(hours);
      if (minutesEl) minutesEl.textContent = formatCountdownValue(minutes);
      if (secondsEl) secondsEl.textContent = formatCountdownValue(seconds);

      if (isExpired) {
        countdownEl.classList.add("expired");
      }
    }

    update();
    setInterval(update, 1000);
  }

  initCountdown();
</script>

<style lang="scss">
  @use "../styles/mixins/breakpoint.scss" as *;

  @keyframes animate-up-fade {
    0% {
      transform: translate3d(0, 100%, 0);
      opacity: 0;
    }
    100% {
      transform: none;
      opacity: 1;
    }
  }

  .countdown {
    display: grid;
    grid-template-columns: auto auto auto;
    gap: 1rem;
    justify-content: center;
    opacity: 0;

    animation-name: animate-up-fade;
    animation-fill-mode: forwards;
    animation-duration: 0.45s;
    animation-timing-function: ease-in-out;
    animation-delay: 1.2s;

    @include bp(desktop) {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
    }
  }

  .countdown-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .countdown-separator {
    font-family: var(--typography-heading-font-family);
    font-size: 64px;
    font-variant-numeric: tabular-nums;

    -webkit-text-stroke: 1px currentColor;
    -webkit-text-fill-color: transparent;
    line-height: 1;

    @include bp(desktop) {
      font-size: 120px;
    }

    &--hide-mobile {
      display: none;

      @include bp(desktop) {
        display: block;
      }
    }
  }

  .countdown-value {
    font-family: var(--typography-heading-font-family);
    font-size: 64px;
    -webkit-text-stroke: 1px currentColor;
    -webkit-text-fill-color: transparent;
    line-height: 1;
    text-align: center;
    width: 112px;

    @include bp(desktop) {
      font-size: 120px;
      width: 200px;
    }
  }

  .countdown-label {
    font-family: var(--typography-heading-font-family);
    font-size: 12px;
    text-transform: uppercase;

    @include bp(desktop) {
      font-size: 20px;
    }
  }
</style>
