---
import Tickertape from "./Tickertape.astro";
import Ticket from "./Ticket.astro";
---

<div class="tickertape-group-container">
  <Ticket />
  <Tickertape class="top" theme="yellow" speed={1.1} offset={0.33} />
  <Tickertape class="middle" theme="blue" speed={0.95} offset={0} />
  <Tickertape class="bottom" theme="purple" speed={1.2} offset={0.66} />
</div>

<style lang="scss">
  @use "../styles/mixins/breakpoint.scss" as *;

  .tickertape-group-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 6rem;
    padding-bottom: 6rem;
    position: relative;

    @include bp(tablet) {
      padding-top: 15rem;
      padding-bottom: 15rem;
      gap: 0;
    }

    :global(.top) {
      transform: rotate(13.669deg);
    }

    :global(.middle) {
      transform: rotate(-2.038deg);
      z-index: -1;
    }

    :global(.bottom) {
      transform: rotate(-10.504deg);
    }
  }
</style>
