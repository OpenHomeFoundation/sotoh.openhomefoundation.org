---
import Container from "../components/Container.astro";
import Content from "../components/Content.astro";
import Button from "../components/Button.astro";
---

<Container containerClass="container--column">
  <Content>
    <h3 class="h2">What is State of the Open Home?</h3>
    <div class="content-container text-center">
      <p>
        State of the Open Home is our annual event where we celebrate our
        community, share what we've built, and imagine what comes next. This
        year, for the first time, you can be in the room with us – join our live
        audience to experience the inspiring conversations, honest debate, and
        creative energy that happen when Open Home advocates get together!
      </p>
    </div>
    <div class="buttons-container">
      <Button class="primary" class="button button--primary" icon="youtube">
        STATE OF THE OPEN HOME 2025
      </Button>
    </div>
  </Content>
</Container>
