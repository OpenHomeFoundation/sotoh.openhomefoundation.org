---
import FullImage from "../components/FullImage.astro";
import Button from "../components/Button.astro";

import sotoh2025 from "../images/Tivolivredenburg.webp";
---

<FullImage
  image={sotoh2025}
  hasScrollEntry={false}
  imageCopyright={`<p class="image-copyright">Photo by <strong>Jelmer de Haas</strong></p>`}
>
  <div class="title-container">
    <h2 class="h2">Tivolivredenburg, Utrecht</h2>

    <Button
      href="https://www.google.com/maps/place/TivoliVredenburg/@52.0926197,5.1129775,15z/data=!4m5!3m4!1s0x0:0xcb73f73b5ccc3eb6!8m2!3d52.0926197!4d5.1129775?shorturl=1"
      target="_blank"
      class="get-directions button button--primary"
      starburst={false}>Get directions</Button
    >
  </div>
  <div class="content-container">
    <p class="p--large">
      TivoliVredenburg is a popular concert venue in the heart of Utrecht. The
      building is a five-minute walk from Utrecht Central Station and surrounded
      by shops and restaurants. Coming by car? You can use one of the six
      garages nearby.
    </p>
    <p class="p--small align-right image-copyright-desktop" aria-hidden="true">
      Photo by <strong>Jelmer de Haas</strong>
    </p>
  </div>
</FullImage>

<style lang="scss">
  @use "../styles/mixins/breakpoint.scss" as *;

  .title-container {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: 2rem;

    @include bp(tablet) {
      margin-bottom: 0;
    }

    .h2 {
      text-align: left;
      color: var(--text-on-light);

      @include bp(desktop) {
        color: var(--text-on-dark);
      }
    }
  }

  :global(.full-image-content) {
    .content-container {
      text-align: left;

      p {
        color: var(--ohf-dark-grey);

        @include bp(desktop) {
          color: var(--text-on-dark);
        }
      }
    }

    :global(.container) {
      :global(.button-text__default) {
        color: var(--text-on-light);
      }

      :global(.button-text__hover) {
        color: var(--sotoh-yellow);
      }
    }
  }

  :global(.full-image-media) {
    position: relative;

    :global(img) {
      border-radius: 0.75rem;
      object-position: center 20% !important;

      @media (max-width: 767px) {
        aspect-ratio: 345/280;
        object-fit: cover;
      }

      @include bp(desktop) {
        border-radius: 0;
      }
    }
  }

  .image-copyright-desktop {
    display: none;

    @include bp(desktop) {
      display: block;
    }
  }

  :global(.image-copyright) {
    position: absolute;
    right: 2.25rem;
    bottom: 0.75rem;
    z-index: 2;

    @include bp(desktop) {
      display: none;
    }
  }
</style>
