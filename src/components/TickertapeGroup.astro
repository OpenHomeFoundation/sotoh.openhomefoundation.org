---
import Tickertape from "./Tickertape.astro";
---

<div class="tickertape-group-container">
  <Tickertape class="top" speed={0.95} offset={0} />
  <Tickertape class="middle" theme="yellow" speed={1.1} offset={0.33} />
  <Tickertape class="bottom" theme="purple" speed={1.2} offset={0.66} />
</div>

<style lang="scss">
  .tickertape-group-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 9rem;
    padding-bottom: 9rem;

    :global(.top) {
      transform: rotate(-2.038deg);
    }

    :global(.middle) {
      transform: rotate(13.669deg);
    }

    :global(.bottom) {
      transform: rotate(-8.504deg);
    }
  }
</style>
