---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Tickertape from "../components/Tickertape.astro";
import Footer from "../sections/Footer.astro";
import Tivolivredenburg from "../sections/Tivolivredenburg.astro";
import EventFAQ from "../sections/EventFAQ.astro";
import Tabs from "../components/Tabs.astro";
import Tab from "../components/Tab.astro";
import TicketInclusioonsFAQ from "../sections/TicketInclusioonsFAQ.astro";
import GettingThere from "../sections/GettingThere.astro";
import Container from "../components/Container.astro";
---

<Layout bodyClass="page-resources">
  <Header slot="header" lightMode />
  <section class="block block-be-part">
    <Tivolivredenburg />
  </section>
  <section class="block block-getting-there">
    <GettingThere />
  </section>
  <section class="block block-event-faq">
    <Container containerClass="container--column">
      <h2 class="h2 text-dark text-center">Got some questions?</h2>
      <Tabs>
        <Tab group="resources" title="The Event" isActive={true}>
          <EventFAQ />
        </Tab>
        <Tab group="resources" title="Ticket and Inclusions">
          <TicketInclusioonsFAQ />
        </Tab>
      </Tabs>
    </Container>
  </section>
  <section class="block block-tickertape">
    <Tickertape theme="yellow" class="full-width" fullWidth={true} />
  </section>
  <Footer />

  <style lang="scss">
    .block {
      &-getting-there {
        padding: 4.5rem 0;
      }

      &-event-faq {
        padding: 0 0 4.5rem;

        .h2 {
          margin-bottom: 4rem;
        }
      }
    }
  </style>
</Layout>
