---
import Container from "../components/Container.astro";
import { ICONS } from "../lib/icons";
---

<Container containerClass="container--column">
  <div class="livestream-container">
    <p class="event-host p--large">
      An event organized by the <Fragment set:html={ICONS["OHFLogo"]} />
    </p>
    <div class="livestream">
      <a
        href="https://www.youtube.com/watch?v=XyAL1to3Lm4"
        target="_blank"
        rel="noopener noreferrer"
        title="Watch the State of the Open Home 2026 livestream on YouTube"></a>
      <iframe
        title="State of the Open Home 2026 livestream"
        src="https://www.youtube.com/embed/XyAL1to3Lm4?autoplay=1&mute=1&modestbranding=1&rel=0&controls=0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen></iframe>
    </div>
  </div>
</Container>

<style lang="scss">
  @use "../styles/mixins/breakpoint.scss" as *;

  @keyframes animate-up-fade {
    0% {
      transform: translate3d(0, 50%, 0);
      opacity: 0;
    }
    100% {
      transform: none;
      opacity: 1;
    }
  }

  p.event-host {
    line-height: 1.4;
    margin-bottom: 0;

    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    gap: 0 0.6rem;
    flex-wrap: wrap;

    @media (prefers-reduced-motion: no-preference) {
      opacity: 0;
      animation-name: animate-up-fade;
      animation-fill-mode: forwards;
      animation-duration: 0.45s;
      animation-timing-function: var(--entry-ease);
      animation-delay: 0.55s;
    }

    :global(svg) {
      width: 100%;
      max-width: 350px;
      max-height: 34px;
    }
  }

  .livestream-container {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    padding-top: 2rem;

    @include bp(large-desktop) {
      padding-top: 4rem;
    }

    .livestream {
      width: 100%;
      max-width: 1000px;
      aspect-ratio: 16 / 9;
      display: flex;
      position: relative;

      a {
        width: 100%;
        height: 100%;
        display: block;
        position: absolute;
        inset: 0;
        z-index: 5;
      }

      iframe {
        width: 100%;
        height: 100%;
        border: none;
        z-index: 2;
      }
    }
  }
</style>
