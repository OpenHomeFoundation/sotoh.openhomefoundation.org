---
import Button from "../components/Button.astro";

import { ICONS } from "../lib/icons";
---

<header class="site-header">
  <div class="site-header__row">
    <a href="/" rel="home" class="logo" aria-label="State of the Open Home">
      <div class="icon-wrap">
        <div class="icon-light">
          <Fragment set:html={ICONS["building"]} />
        </div>
        <div class="icon-dark">
          <Fragment set:html={ICONS["building"]} />
        </div>
      </div>
      <div class="icon-wrap">
        <div class="icon-light">
          <Fragment set:html={ICONS["privacy"]} />
        </div>
        <div class="icon-dark">
          <Fragment set:html={ICONS["privacy"]} />
        </div>
      </div>
      <div class="icon-wrap">
        <div class="icon-light">
          <Fragment set:html={ICONS["choice"]} />
        </div>
        <div class="icon-dark">
          <Fragment set:html={ICONS["choice"]} />
        </div>
      </div>
      <div class="icon-wrap">
        <div class="icon-light">
          <Fragment set:html={ICONS["sustainability"]} />
        </div>
        <div class="icon-dark">
          <Fragment set:html={ICONS["sustainability"]} />
        </div>
      </div>
    </a>

    <div class="site-header__ctas">
      <Button href="/" class="button button--hollow button--tickets" disabled>
        Tickets coming soon
      </Button>
    </div>

    <div class="site-header-burger">
      <input type="checkbox" id="site-header-burger-toggle" />
      <label class="site-header-burger-label" for="site-header-burger-toggle"
      ></label>
      <div class="site-header-burger-icon"></div>
    </div>
  </div>

  <div class="mobile-nav">
    <ul>
      <li>
        <a href="/">Home <Fragment set:html={ICONS["chevronDown"]} /></a>
        <ul>
          <li><a href="/">What is State of the Open Home?</a></li>
          <li><a href="/">Why we’re building in the open</a></li>
          <li><a href="/">Be part of the conversation</a></li>
        </ul>
      </li>
      <li class="disabled">
        <a href="#">Speakers &amp; Agenda <span>Coming Soon</span></a>
      </li>
      <li class="disabled">
        <a href="#">The Venue <span>Coming Soon</span></a>
      </li>
    </ul>
  </div>
</header>

<style lang="scss">
  @use "../styles/mixins/breakpoint.scss" as *;

  .site-header {
    --header-bgc: transparent;
    --link-color: var(--text-on-dark);
    --link-hover-color: var(--ohf-dark-blue);

    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    background-color: var(--header-bgc);

    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;

    padding: 20px 0;
    transition:
      0.3s background-color ease-in-out,
      0.3s padding ease-in-out;

    overflow-x: clip;

    @include bp(tablet) {
      padding: 40px 0;
    }

    &.is-scrolled {
      --header-bgc: rgba(255, 255, 255, 0.5);

      backdrop-filter: blur(6px);

      @include bp(tablet) {
        padding: 20px 0;
      }

      .logo {
        .icon-wrap {
          @for $i from 1 through 4 {
            &:nth-child(#{$i}) {
              .icon-light,
              .icon-dark {
                transition-delay: #{($i - 1) * 100}ms;
              }
            }
          }
        }

        .icon-light {
          transform: translate3d(0, 100%, 0);
        }

        .icon-dark {
          transform: translate3d(0, 100%, 0);
        }
      }

      .site-header__ctas {
        :global(.button--tickets) {
          border: 2px solid var(--ohf-dark-blue);
          color: var(--ohf-dark-blue);
        }
      }
    }

    &__row {
      width: 100%;
      max-width: 1200px;

      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 1rem;

      padding: 0 1rem;

      @include bp(tablet) {
        gap: 1.5rem;
      }

      @include bp(desktop) {
        gap: 2rem;
      }

      @include bp(large-desktop) {
        padding: 0;
      }
    }

    .logo {
      width: 120px;

      display: flex;
      flex-direction: row;

      transform: translate3d(0, 3px, 0);

      @include bp(large-mobile) {
        width: 150px;
      }

      @include bp(desktop) {
        width: 183px;
      }

      :global(svg) {
        width: 100%;
        height: auto;
      }

      .icon-wrap {
        position: relative;
        overflow: hidden;

        display: flex;
        flex-direction: column;

        &:hover {
          .icon-light,
          .icon-dark {
            transform: translate3d(0, 100%, 0);
            transition-delay: 0ms;
          }
        }

        .icon-light,
        .icon-dark {
          transition: transform 0.3s ease-in-out;
        }

        .icon-light {
          color: var(--ohf-light-grey);
        }

        .icon-dark {
          color: var(--ohf-dark-blue);
          position: absolute;
          bottom: 100%;
        }
      }
    }

    nav {
      flex-grow: 1;

      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: center;
    }

    nav {
      display: none;

      @include bp(tablet) {
        display: flex;
      }
    }

    ul {
      width: 100%;
      max-width: 600px;
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: space-evenly;

      li {
        position: relative;
        flex-shrink: 0;

        &.disabled {
          pointer-events: none;
        }

        &:has(ul) {
          a {
            display: flex;
            flex-direction: row;
            align-items: center;
            justify-content: center;
            gap: 0.375rem;

            :global(svg) {
              transition: transform 0.3s ease-in-out;
            }
          }
        }

        &:hover() {
          > a {
            --link-color: var(--ohf-dark-blue);

            :global(svg) {
              transform: rotate(180deg);
            }
          }

          ul {
            opacity: 1;
            pointer-events: all;
          }
        }

        a {
          text-transform: uppercase;
          color: var(--link-color);
          text-decoration: none;
          flex-shrink: 0;
          font-family: var(--typography-heading-font-family);
          font-size: 0.75rem;
          transition: 0.3s color ease-in-out;

          &:has(> span) {
            text-decoration: line-through;

            @include bp(desktop) {
              text-decoration: none;
            }
          }

          > span {
            display: none;
            font-family: var(--typography-body-font-family);
            text-transform: none;
            margin-left: 0.625rem;

            @include bp(desktop) {
              display: inline-block;
            }
          }
        }
      }

      ul {
        width: 300px;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;

        position: absolute;
        top: 100%;
        left: -1.25rem;
        padding: 1.5rem 1.25rem 1rem;
        opacity: 0;
        pointer-events: none;

        border-radius: 1.5rem;
        background-color: var(--header-bgc);

        transition: 0.3s opacity ease-in-out;

        li {
          a {
            font-family: var(--typography-body-font-family);
            text-transform: none;

            &:hover {
              color: var(--link-hover-color);
            }
          }
        }
      }
    }

    &__ctas {
      display: flex;
      flex-direction: row;
      gap: 8px;
      margin-left: auto;
    }

    &-burger {
      display: inline-block;
      height: calc(
        var(--burger-bar-height) + (var(--burger-bar-height) / 2) +
          (var(--burger-bar-spacing) - var(--burger-bar-height)) * 2
      );
      position: relative;
      width: var(--burger-bar-width);

      background-color: var(--ohf-dark-blue);
      padding: 1rem;
      border-radius: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      display: none;

      @include bp(tablet) {
        display: none;
      }

      input[type="checkbox"] {
        display: none;

        &:checked ~ .site-header-burger-icon {
          background-color: transparent;

          &:before,
          &:after {
            transform-origin: 50% 50%;
          }

          &:before {
            top: 0;
            transform: rotate(45deg);
          }

          &:after {
            bottom: 0;
            transform: rotate(-45deg);
          }
        }
      }

      label {
        inset: 0;
        position: absolute;

        cursor: pointer;
      }

      &-icon {
        background-color: var(--burger-bar-color);
        border-radius: var(--burger-border-radius);
        height: var(--burger-bar-height);
        pointer-events: none;
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        transition: background-color calc(var(--burger-transition-speed) / 1.5);
        width: var(--burger-bar-width);

        &:before,
        &:after {
          background-color: var(--burger-bar-color);
          border-radius: var(--burger-border-radius);
          content: " ";
          height: var(--burger-bar-height);
          position: absolute;
          transition:
            transform var(--burger-transition-speed),
            top var(--burger-transition-speed),
            bottom var(--burger-transition-speed);
          width: 100%;
        }

        &:before {
          top: calc(-1 * var(--burger-bar-spacing));
        }

        &:after {
          bottom: calc(-1 * var(--burger-bar-spacing));
        }
      }
    }

    &:has(.site-header-burger input:checked) {
      background-color: var(--header-bgc);

      .mobile-nav {
        transform: translate3d(0, 0, 0);
        pointer-events: all;

        @include bp(tablet) {
          opacity: 0;
          pointer-events: none;
        }
      }
    }
  }

  .mobile-nav {
    width: 100%;
    position: absolute;
    top: 70px; // header-height
    right: 0;
    padding: 1rem 1rem 2rem;
    z-index: 1;
    pointer-events: none;

    transform: translate3d(100%, 0, 0);
    transition: 0.3s transform ease-in-out;

    display: flex;
    flex-direction: column;
    align-items: center;

    background-color: var(--header-bgc);

    ul {
      display: flex;
      flex-direction: column;
      gap: 1rem;

      ul {
        position: relative;
        padding-top: 1rem;
        inset: 0;
        opacity: 1;
        align-items: center;
      }
    }
  }
</style>

<script>
  const header = document.querySelector(".site-header");
  if (header) {
    const onScroll = () => {
      if (window.scrollY > 40) {
        header.classList.add("is-scrolled");
      } else if (window.scrollY === 0) {
        header.classList.remove("is-scrolled");
      }
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }
</script>
