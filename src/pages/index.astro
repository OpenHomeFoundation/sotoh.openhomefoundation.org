---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Countdown from "../components/Countdown.astro";
import Building from "../sections/Building.astro";
import Ticket from "../components/Ticket.astro";
import WhatIs from "../sections/WhatIs.astro";
import Carousel from "../components/Carousel.astro";
import Why from "../sections/Why.astro";
import Tickertape from "../components/Tickertape.astro";
import Speakers from "../sections/Speakers.astro";
import BePart from "../sections/BePart.astro";
import Footer from "../sections/Footer.astro";
import Agenda from "../sections/Agenda.astro";
---

<Layout bodyClass="page-home">
  <Header slot="header" />
  <section class="block block-hero">
    <Hero />
  </section>
  <section class="block block-countdown">
    <Countdown />
  </section>
  <section class="block block-ticket" id="ticket">
    <Ticket />
  </section>
  <section class="block block-building">
    <Building />
  </section>
  <section class="block block-what-is" id="what-is-state-of-the-open-home">
    <WhatIs />
  </section>
  <section class="block block-image-carousel">
    <Carousel />
  </section>
  <section class="block block-why" id="why-we-are-building-in-the-open">
    <Why />
  </section>
  <section class="block block-speakers" id="speakers">
    <Speakers />
  </section>
  <section class="block block-agenda" id="agenda">
    <Agenda />
  </section>
  <section class="block block-be-part" id="be-part-of-the-conversation">
    <BePart />
  </section>
  <section class="block block-tickertape">
    <Tickertape theme="yellow" class="full-width" fullWidth={true} />
  </section>
  <Footer slot="footer" />
</Layout>

<style lang="scss">
  @use "../styles/mixins/breakpoint.scss" as *;

  .block {
    &-hero {
      margin-bottom: 2rem;
    }

    &-ticket {
      padding: 3.5rem 1rem;

      @include bp(tablet) {
        padding: 5rem 1rem;
      }

      @include bp(desktop) {
        padding: 7rem 0;
      }
    }

    &-building {
      padding-bottom: 4rem;

      @include bp(tablet) {
        padding-bottom: 6rem;
      }
    }

    &-image-carousel {
      padding-top: 2rem;
      margin-bottom: 5rem;

      @include bp(desktop) {
        padding-top: 4rem;
      }
    }

    &-what-is,
    &-why {
      margin-bottom: 5rem;
    }

    &-speakers {
      overflow: hidden;
      margin-top: 5rem;
      margin-bottom: 5rem;

      @include bp(desktop) {
        margin-top: 10rem;
        margin-bottom: 10rem;
      }
    }
  }
</style>
