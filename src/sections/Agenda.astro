---
import Container from "../components/Container.astro";
import Content from "../components/Content.astro";
import SpeakerCard from "../components/SpeakerCard.astro";

import { agenda } from "../lib/agenda";
---

<Container containerClass="container--column">
  <Content>
    <h2 class="h2">Program: Building in the open</h2>
    <div class="agenda">
      {
        agenda.map((item) => (
          <div class="agenda__row">
            <div class="agenda__time">{item.time}</div>
            <div class="agenda__items">
              {item.items.map((subItem) => (
                <div class="agenda__item">
                  <div class="agenda__title">{subItem.title}</div>
                  <!-- If we have segments -->
                  {subItem.segments && (
                    <div class="agenda__segments">
                      {subItem.segments.map((segment) => (
                        <div class="agenda__segment">
                          <div class="agenda__segment-title">{segment.title}</div>
                          <!-- If we have speakers for this segment -->
                          {segment.speakers && (
                            <div class="agenda__segment-speakers">
                              {segment.speakers.map((speaker) => (
                                <span class="agenda__speaker">{speaker}</span>
                              ))}
                            </div>
                          )}
                        </div>
                      ))}
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </Content>
</Container>

<style lang="scss" is:global>
  @use "../styles/mixins/breakpoint.scss" as *;

  .agenda{
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: 32px;

    &__row{
      display: flex;
      flex-direction: column;
      gap: 12px;

      @include bp(tablet){
        flex-direction: row;
        gap: 24px;
      }
    }

    &__time{
      font-family: var(--typography-heading-font-family);
      font-weight: var(--typography-heading-font-weight);
      line-height: 1.2;
      display: grid;
      place-items: center;
      white-space: nowrap;
      padding: 20px;


      @include bp(tablet){
        font-size: 20px;
        max-width: 200px;
        padding: 40px 20px;
      }

      @include bp(desktop){
        font-size: 24px;
        max-width: 266px;
      }
    }

    &__time, &__items{
      flex-grow: 1;
    }

    &__time, &__item{
      background: rgba(247, 246, 242, .1);
      border: 1px solid var(--ohf-light-grey);
      border-radius: 1rem;
    }

    &__item{
      padding: 28px 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;

      @include bp(tablet){
        align-items: flex-start;
        text-align: left;
        padding: 40px;
      }
    }

    &__title{
      font-size: 20px;

      @include bp(tablet){
        font-size: 24px;
      }

      @include bp(desktop){
        font-size: 32px;
      }
    }

    &__items{
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    &__segments{
      display: flex;
      flex-direction: column;
      gap: 20px;
      margin-top: 20px;
    }

    &__segment{
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    &__segment-title{
      font-weight: 500;
    }

    &__segment-speakers{
      font-weight: 300;
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: center;

      @include bp(tablet){
        justify-content: flex-start;
      }

      .agenda__speaker{
        display: inline-block;

        &:not(:last-child)::after{
          content: "•"; // bullet

          padding: 0 6px;

          @include bp(tablet){
            padding: 0 16px;
          }
        }
      }
    }

    &__segment-title, &__segment-speakers{
      @include bp(tablet){
        font-size: 20px;
      }

      @include bp(desktop){
        font-size: 24px;
      }
    }
  }
</style>
