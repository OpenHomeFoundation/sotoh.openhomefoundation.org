---
import { ICONS, type ICON } from "../lib/icons";

interface Props {
  class?: string;
  href?: string;
  icon: ICON;
}
const { class: className = "", href = "/error", icon } = Astro.props;
---

<a class={className} href={href}>
  {
    icon ? (
      <div class="button-icon">
        <Fragment set:html={ICONS[icon]} />
      </div>
    ) : null
  }
  <slot />
</a>

<style lang="scss" is:global>
  .button {
    color: var(--text-on-dark);
    padding: 12px 24px;
    border-radius: 40px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-family: var(--typography-heading-font-family);
    font-weight: var(--typography-heading-font-weight);
    font-size: 0.75rem;
    gap: 8px;

    &-icon {
      display: grid;
      place-items: center;
      background-color: white;
      height: 24px;
      width: 24px;
      border-radius: 50%;
    }

    &--hollow {
      border: 2px solid var(--sotoh-yellow);
    }

    &--primary {
      background-color: var(--sotoh-yellow);
      color: var(--ohf-dark-blue);

      &:hover {
        color: var(--sotoh-yellow);
        background-color: var(--ohf-dark-blue);
      }
    }
  }
</style>
