---
// Import global styles
import "../styles/_variables.scss";
import "../styles/_reset.scss";
import "../styles/_global.scss";
import "../styles/_typography.scss";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  includeEventSchema?: boolean;
  noindex?: boolean;
}

const defaultTitle = "State of the Open Home - Open Home Foundation";
const defaultDescription =
  "Join us in Utrecht on April 8 for State of the Open Home 2026. Your chance to celebrate, connect, and discover what's next - visit our site to learn more!";

const {
  title = defaultTitle,
  description = defaultDescription,
  canonical = "https://sotoh.openhomefoundation.org/",
  includeEventSchema = true,
  noindex = false,
} = Astro.props;

const fullTitle =
  title === defaultTitle ? title : `${title} - Open Home Foundation`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#1a2744" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Open Home Foundation" />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta
      property="og:image"
      content="https://sotoh.openhomefoundation.org/sotoh-share-image.webp"
    />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="State of the Open Home 2026" />
    <meta
      property="og:site_name"
      content="State of the Open Home - Open Home Foundation"
    />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content="https://sotoh.openhomefoundation.org/sotoh-share-image.webp"
    />
    <meta name="twitter:image:alt" content="State of the Open Home 2026" />

    <!-- JSON-LD Schema -->
    {includeEventSchema && (
      <script type="application/ld+json" is:inline>
        {
          "@context": "https://schema.org",
          "@type": "Event",
          "name": "State of the Open Home 2026 - Open Home Foundation",
          "description": "Join us in Utrecht on April 8 for State of the Open Home 2026. Your chance to celebrate, connect, and discover what's next!",
          "url": "https://sotoh.openhomefoundation.org/",
          "startDate": "2026-04-08",
          "eventStatus": "https://schema.org/EventScheduled",
          "eventAttendanceMode": "https://schema.org/MixedEventAttendanceMode",
          "location": {
            "@type": "Place",
            "name": "Utrecht",
            "address": {
              "@type": "PostalAddress",
              "addressLocality": "Utrecht",
              "addressCountry": "NL"
            }
          },
          "organizer": {
            "@type": "Organization",
            "name": "Open Home Foundation",
            "url": "https://www.openhomefoundation.org"
          },
          "image": "https://sotoh.openhomefoundation.org/sotoh-share-image.webp"
        }
      </script>
    )}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&family=Special+Gothic+Expanded+One&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot name="header" />
    <div id="smooth-wrapper">
      <div id="smooth-content">
        <main>
          <slot />
        </main>
        <slot name="footer" />
      </div>
    </div>
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
  }

  body.menu-open {
    overflow: hidden;
  }

  #smooth-content {
    padding-top: var(--header-height);
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { ScrollSmoother } from "gsap/ScrollSmoother";

  gsap.registerPlugin(ScrollTrigger, ScrollSmoother);

  const mm = gsap.matchMedia();

  mm.add(
    {
      reduceMotion: "(prefers-reduced-motion: reduce)",
      normal: "(prefers-reduced-motion: no-preference)",
    },
    (context) => {
      const { reduceMotion } = context.conditions!;

      // Skip ScrollSmoother in Playwright tests (breaks trace playback)
      const isPlaywrightTest = (window as any).__PLAYWRIGHT_TEST__;

      if (!reduceMotion && !isPlaywrightTest) {
        ScrollSmoother.create({
          smooth: 1,
          effects: true,
        });
      }

      if (reduceMotion) {
        gsap.defaults({ duration: 0 });
      }

      // Fade up animation for elements with .animate--fade-up
      if (!reduceMotion) {
        document.querySelectorAll(".animate--fade-up").forEach((el) => {
          gsap.from(el, {
            y: 40,
            opacity: 0,
            duration: 0.8,
            ease: "power3.out",
            scrollTrigger: {
              trigger: el,
              start: "top 95%",
              toggleActions: "play none none none",
            },
          });
        });
      }
    },
  );

  import { initMatter } from "../lib/matter";
  const siteFooter = document.querySelector("#matter-container");
  if (siteFooter) {
    ScrollTrigger.create({
      trigger: siteFooter,
      start: "top bottom",
      once: true,
      onEnter: () => {
        initMatter();
      },
    });
  }

  // Debounced ScrollTrigger refresh on resize
  let resizeTimeout: ReturnType<typeof setTimeout>;
  window.addEventListener(
    "resize",
    () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => {
        ScrollTrigger.refresh();
      }, 200);
    },
    { passive: true },
  );
</script>
