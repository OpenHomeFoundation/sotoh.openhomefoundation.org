---
import Button from "../components/Button.astro";
import CopyEmail from "../components/CopyEmail.astro";
import TextWipe from "../components/TextWipe.astro";

import { ICONS } from "../lib/icons";

interface Props {
  lightMode?: boolean;
}
const { lightMode = false } = Astro.props;
---

<header class:list={["site-header", { "light-mode": lightMode }]}>
  <div class="site-header__row">
    <a href="/" rel="home" class="logo" aria-label="State of the Open Home">
      <div class="icon-wrap">
        <div class="icon-light">
          <Fragment set:html={ICONS["building"]} />
        </div>
        <div class="icon-dark">
          <Fragment set:html={ICONS["building"]} />
        </div>
      </div>
      <div class="icon-wrap">
        <div class="icon-light">
          <Fragment set:html={ICONS["privacy"]} />
        </div>
        <div class="icon-dark">
          <Fragment set:html={ICONS["privacy"]} />
        </div>
      </div>
      <div class="icon-wrap">
        <div class="icon-light">
          <Fragment set:html={ICONS["choice"]} />
        </div>
        <div class="icon-dark">
          <Fragment set:html={ICONS["choice"]} />
        </div>
      </div>
      <div class="icon-wrap">
        <div class="icon-light">
          <Fragment set:html={ICONS["sustainability"]} />
        </div>
        <div class="icon-dark">
          <Fragment set:html={ICONS["sustainability"]} />
        </div>
      </div>
    </a>

    <div class="site-header__ctas">
      <Button href="/" class="button button--primary button--tickets">
        Buy tickets
      </Button>
    </div>

    <div class="site-header-burger">
      <input type="checkbox" id="site-header-burger-toggle" />
      <label class="site-header-burger-label" for="site-header-burger-toggle"
      ></label>
      <div class="site-header-burger-icon"></div>
    </div>
  </div>

  <div class="mobile-nav">
    <div class="mobile-nav__inner">
      <ul>
        <li>
          <TextWipe href="/">Home</TextWipe>
          <ul>
            <li>
              <TextWipe href="/#what-is-state-of-the-open-home"
                >What is State of the Open Home?</TextWipe
              >
            </li>
            <li>
              '
              <TextWipe href="/#why-we-are-building-in-the-open"
                >Why we’re building in the open</TextWipe
              >
            </li>
            <li>
              <TextWipe href="/#be-part-of-the-conversation"
                >Be part of the conversation</TextWipe
              >
            </li>
          </ul>
        </li>
      </ul>

      <div class="meta-links">
        <CopyEmail email="events@openhomefoundation.org" class="help-link" />
      </div>
    </div>
  </div>
</header>

<style lang="scss">
  @use "../styles/mixins/breakpoint.scss" as *;

  .site-header {
    --header-bgc: transparent;
    --header-bgc-active: rgba(255, 255, 255, 0.5);
    --link-color: var(--text-on-dark);
    --link-hover-color: var(--ohf-dark-blue);
    --burger-bgc: transparent;
    --blur: blur(6px);

    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;

    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;

    padding: 20px 0;
    transition:
      0.3s background-color ease-in-out,
      0.3s padding ease-in-out;

    @include bp(tablet) {
      padding: 40px 0;
    }

    &.is-scrolled,
    &.light-mode {
      --burger-bgc: var(--ohf-dark-blue);

      .logo {
        .icon-wrap {
          @for $i from 1 through 4 {
            &:nth-child(#{$i}) {
              .icon-light,
              .icon-dark {
                transition-delay: #{($i - 1) * 100}ms;
              }
            }
          }
        }

        .icon-light {
          transform: translate3d(0, 100%, 0);
        }

        .icon-dark {
          transform: translate3d(0, 100%, 0);
        }
      }
    }

    &.is-scrolled {
      --header-bgc: var(--header-bgc-active);

      .mobile-nav {
        opacity: 1;
        transform: translateY(calc(-100% + 72px));

        @include bp(large-mobile) {
          transform: translateY(calc(-100% + 86px));
        }
      }

      @include bp(tablet) {
        padding: 20px 0;
      }
    }

    &.light-mode {
      .logo .icon-wrap {
        .icon-light,
        .icon-dark {
          transition-delay: 0ms;
        }
      }
    }

    &__row {
      width: 100%;
      max-width: 1200px;

      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 1rem;

      position: relative;
      z-index: 2;

      padding: 0 1rem;

      @include bp(tablet) {
        gap: 1.5rem;
      }

      @include bp(desktop) {
        gap: 2rem;
      }

      @include bp(large-desktop) {
        padding: 0;
      }
    }

    .logo {
      width: 120px;
      display: flex;
      flex-direction: row;

      @include bp(large-mobile) {
        width: 150px;
      }

      @include bp(desktop) {
        width: 183px;
      }

      :global(svg) {
        width: 100%;
        height: auto;
      }

      .icon-wrap {
        position: relative;
        overflow: hidden;

        display: flex;
        flex-direction: column;

        &:hover {
          .icon-light,
          .icon-dark {
            transform: translate3d(0, 100%, 0);
            transition-delay: 0ms;
          }
        }

        .icon-light,
        .icon-dark {
          transition: transform 0.3s ease-in-out;
          display: flex;
        }

        .icon-light {
          color: var(--ohf-light-grey);
        }

        .icon-dark {
          color: var(--ohf-dark-blue);
          position: absolute;
          bottom: 100%;
        }
      }
    }

    &__ctas {
      display: flex;
      flex-direction: row;
      gap: 8px;
      margin-left: auto;
      display: none;

      @include bp(large-mobile) {
        display: flex;
      }
    }

    &-burger {
      display: inline-block;
      height: calc(
        var(--burger-bar-height) + (var(--burger-bar-height) / 2) +
          (var(--burger-bar-spacing) - var(--burger-bar-height)) * 2
      );
      position: relative;
      width: var(--burger-bar-width);

      background-color: var(--burger-bgc);
      padding: 1rem;
      border-radius: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      transition: 0.3s background-color ease-in-out;
      margin-left: auto;

      @include bp(large-mobile) {
        margin: 0;
      }

      input[type="checkbox"] {
        display: none;

        &:checked ~ .site-header-burger-icon {
          background-color: transparent;

          &:before,
          &:after {
            transform-origin: 50% 50%;
          }

          &:before {
            top: 0;
            transform: rotate(45deg);
          }

          &:after {
            bottom: 0;
            transform: rotate(-45deg);
          }
        }
      }

      label {
        inset: 0;
        position: absolute;

        cursor: pointer;
      }

      &-icon {
        background-color: var(--burger-bar-color);
        border-radius: var(--burger-border-radius);
        height: var(--burger-bar-height);
        pointer-events: none;
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        transition: background-color calc(var(--burger-transition-speed) / 1.5);
        width: var(--burger-bar-width);

        &:before,
        &:after {
          background-color: var(--burger-bar-color);
          border-radius: var(--burger-border-radius);
          content: " ";
          height: var(--burger-bar-height);
          position: absolute;
          transition:
            transform var(--burger-transition-speed),
            top var(--burger-transition-speed),
            bottom var(--burger-transition-speed);
          width: 100%;
        }

        &:before {
          top: calc(-1 * var(--burger-bar-spacing));
        }

        &:after {
          bottom: calc(-1 * var(--burger-bar-spacing));
        }
      }
    }

    &:has(.site-header-burger input:checked) {
      --header-bgc: var(--header-bgc-active);
      --burger-bgc: var(--ohf-dark-blue);

      .logo {
        .icon-wrap {
          @for $i from 1 through 4 {
            &:nth-child(#{$i}) {
              .icon-light,
              .icon-dark {
                transition-delay: #{($i - 1) * 100}ms;
              }
            }
          }
        }

        .icon-light {
          transform: translate3d(0, 100%, 0);
        }

        .icon-dark {
          transform: translate3d(0, 100%, 0);
        }
      }

      &:before {
        transform: scaleY(0);
        transition: 0.15s transform ease-in-out;
      }

      .mobile-nav {
        transform: none;
        border-radius: 0 0 1.5rem 1.5rem;
        opacity: 1;
        pointer-events: all;

        .mobile-nav__inner > ul,
        .mobile-nav__inner > .meta-links {
          opacity: 1;
        }

        .mobile-nav__inner > ul {
          transition-delay: 0.35s;
        }

        .mobile-nav__inner > .meta-links {
          transition-delay: 0.45s;
        }

        .mobile-nav__inner::-webkit-scrollbar-thumb {
          background-color: var(--ohf-dark-blue);
          transition-delay: 0.5s;
        }
      }
    }
  }

  .mobile-nav {
    width: 100%;
    max-height: 100vh;
    position: absolute;
    top: 0;
    right: 0;
    padding: 2rem 1rem 1rem;
    z-index: 1;
    pointer-events: none;
    opacity: 0;
    transform: translate3d(0, -100%, 0);
    transform-origin: center top;
    transition:
      0.45s transform ease-in-out,
      0.3s background-color ease-in-out,
      0.3s border-radius ease-in-out,
      0.3s opacity ease-in-out;
    backdrop-filter: var(--blur);
    display: flex;
    flex-direction: column;
    align-items: center;

    background-color: var(--header-bgc);

    @include bp(tablet) {
      padding: 120px 1rem 1rem;
    }

    &__inner {
      width: 100%;
      max-width: 1200px;
      padding-bottom: 1rem;
      overflow-y: auto;

      &::-webkit-scrollbar {
        width: 6px;
        background: transparent;
      }

      &::-webkit-scrollbar-track {
        background: transparent;
      }

      &::-webkit-scrollbar-thumb {
        background-color: transparent;
        border-radius: 4px;
        transition: background-color 0.3s ease-in-out;
      }

      display: flex;
      flex-direction: column;
      align-items: center;

      > ul,
      > .meta-links {
        opacity: 0;
        transition: opacity 0.3s ease-in-out;
      }

      > ul {
        transition-delay: 0s;
      }

      > .meta-links {
        transition-delay: 0s;
      }

      ul {
        width: 100%;
        max-width: 400px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 4rem 0 2rem;
        text-align: center;

        @include bp(large-mobile) {
          padding: 5rem 0;
        }

        li {
          width: 100%;
          font-family: var(--typography-heading-font-family);

          padding: 1.5rem 0;
          border-top: 1px solid var(--ohf-grey);

          @include bp(tablet) {
            padding: 2rem 0;
          }

          &:first-child {
            border-top: none;
            padding-top: 0;
          }

          :global(.text-wipe) {
            color: var(--ohf-dark-blue);

            :global(.text-wipe__hover) {
              color: var(--ohf-dark-blue);
              text-decoration: underline;
            }
          }

          a {
            font-size: clamp(1.5rem, 1.3239rem + 0.7512vw, 2rem);
            text-transform: uppercase;
          }

          ul {
            padding: 0.5rem 0 0;
            gap: 0.5rem;

            @include bp(tablet) {
              padding: 1rem 0 0;
              gap: 1rem;
            }

            li {
              border: none;
              padding: 0;

              a {
                font-family: var(--typography-body-font-family);
                font-weight: 400;
                text-transform: none;
                font-size: clamp(1.125rem, 0.993rem + 0.5634vw, 1.5rem);
              }
            }
          }
        }
      }

      .meta-links {
        width: 100%;

        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: 1rem;
        font-size: 0.9375rem;

        @include bp(large-mobile) {
          justify-content: flex-end;
          flex-wrap: nowrap;
        }

        :global(.text-wipe) {
          color: var(--ohf-dark-blue);

          :global(.text-wipe__hover) {
            color: var(--ohf-dark-blue);
            text-decoration: underline;
          }
        }

        :global(.help-link) {
          font-weight: 700;
          color: var(--ohf-dark-blue);

          :global(.copy-email__hover) {
            color: var(--ohf-dark-blue);
            text-decoration: underline;
          }

          @include bp(large-mobile) {
            margin-right: auto;
          }
        }
      }
    }
  }
</style>

<script>
  import { ScrollSmoother } from "gsap/ScrollSmoother";

  const header = document.querySelector(".site-header");
  if (header) {
    const onScroll = () => {
      if (window.scrollY > 40) {
        header.classList.add("is-scrolled");
      } else if (window.scrollY === 0) {
        header.classList.remove("is-scrolled");
      }
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }

  const menuToggle = document.querySelector<HTMLInputElement>(
    "#site-header-burger-toggle",
  );
  if (menuToggle) {
    menuToggle.addEventListener("change", () => {
      const smoother = ScrollSmoother.get();
      if (smoother) {
        smoother.paused(menuToggle.checked);
      }
      document.body.classList.toggle("menu-open", menuToggle.checked);
    });

    // Close menu on Escape key
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && menuToggle.checked) {
        menuToggle.checked = false;
        menuToggle.dispatchEvent(new Event("change"));
      }
    });

    // Close menu when clicking outside
    document.addEventListener("click", (e) => {
      if (!menuToggle.checked) return;
      const target = e.target as HTMLElement;
      const header = document.querySelector(".site-header");
      if (header && !header.contains(target)) {
        menuToggle.checked = false;
        menuToggle.dispatchEvent(new Event("change"));
      }
    });
  }
</script>
