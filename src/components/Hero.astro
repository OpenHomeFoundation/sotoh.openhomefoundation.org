---
import Container from "../components/Container.astro";
import Content from "../components/Content.astro";

import { ICONS } from "../lib/icons";

import BrandIcon from "./BrandIcon.astro";
---

<Container containerClass="container--hero">
  <p class="event-host p--large">
    An event organized by the <Fragment set:html={ICONS["OHFLogo"]} />
  </p>

  <div class="brand-icons">
    <BrandIcon icon="building" />
    <BrandIcon icon="privacy" />
    <BrandIcon icon="choice" />
    <BrandIcon icon="sustainability" />
  </div>

  <Content>
    <h1 class="h1">STATE OF THE OPEN HOME</h1>

    <div class="recap-container">
      <p class="h2">2026 Event Highlights</p>
      <div class="video-container embed-facade">
        <div id="video-overlay"></div>
        <iframe
          width="1080"
          height="608"
          data-src="https://www.youtube.com/embed/TTsSRewv9ag?si=Ti547uieFuUM55tL&enablejsapi=1"
          title="State of the Open Home 2026 Highlights"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen></iframe>
      </div>
    </div>
  </Content>
</Container>

<style lang="scss">
  @use "../styles/mixins/breakpoint.scss" as *;

  @keyframes animate-up-fade {
    0% {
      transform: translate3d(0, 50%, 0);
      opacity: 0;
    }
    100% {
      transform: none;
      opacity: 1;
    }
  }

  img {
    width: 100%;
    height: auto;
  }

  // button anim up
  :global(.button) {
    position: relative;
    overflow: visible;

    @media (prefers-reduced-motion: no-preference) {
      opacity: 0;
      animation-name: animate-up-fade;
      animation-fill-mode: forwards;
      animation-duration: 0.5s;
      animation-timing-function: var(--entry-ease);
      animation-delay: 0.75s;
    }
  }

  h1 {
    margin-bottom: 0;
    text-align: center;

    @media (prefers-reduced-motion: no-preference) {
      opacity: 0;
      animation-name: animate-up-fade;
      animation-fill-mode: forwards;
      animation-duration: 0.5s;
      animation-timing-function: var(--entry-ease);
      animation-delay: 0.65s;
    }
  }

  p.event-host {
    line-height: 1.4;
    margin-bottom: 0;

    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    gap: 0 0.6rem;
    flex-wrap: wrap;

    @media (prefers-reduced-motion: no-preference) {
      opacity: 0;
      animation-name: animate-up-fade;
      animation-fill-mode: forwards;
      animation-duration: 0.45s;
      animation-timing-function: var(--entry-ease);
      animation-delay: 0.55s;
    }

    :global(svg) {
      width: 100%;
      max-width: 350px;
      max-height: 34px;
    }
  }

  .recap-container {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;

    @include bp(desktop) {
      margin-top: 2.5rem;
    }

    p {
      text-align: center;
      margin-bottom: 1rem;

      @include bp(desktop) {
        margin-bottom: 2.5rem;
      }
    }

    .video-container {
      position: relative;
      z-index: 1;
      width: 100%;
      background-color: rgba(255, 255, 255, 0.25);

      display: flex;

      #video-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0);
        z-index: 1;
        pointer-events: none;
        transition: background 0.5s ease;

        @media (prefers-reduced-motion: reduce) {
          transition: none;
        }

        &.active {
          background: rgba(0, 0, 0, 0.75);
        }
      }

      iframe {
        position: relative;
        z-index: 2;
        width: 100%;
        height: auto;
        aspect-ratio: 16 / 9;
      }
    }
  }

  .brand-icons {
    // 2x2 on mobile, 4x1 on desktop
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat(2, auto);

    @media (prefers-reduced-motion: no-preference) {
      opacity: 0;
      animation-name: animate-up-fade;
      animation-fill-mode: forwards;
      animation-duration: 0.85s;
      animation-timing-function: var(--entry-ease);
    }

    @include bp(desktop) {
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: auto;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const overlay = document.getElementById("video-overlay")!;

    let player: any = null;
    let loaded = false;

    const pauseVideo = () => player?.pauseVideo();

    const initYTPlayer = (iframe: HTMLIFrameElement) => {
      const tag = document.createElement("script");
      tag.src = "https://www.youtube.com/iframe_api";
      document.head.appendChild(tag);

      const previousReady = (window as any).onYouTubeIframeAPIReady;
      (window as any).onYouTubeIframeAPIReady = () => {
        previousReady?.();
        player = new (window as any).YT.Player(iframe, {
          events: {
            onStateChange: (event: { data: number }) => {
              const PLAYING = 1;
              overlay.classList.toggle("active", event.data === PLAYING);
            },
          },
        });
      };

      // Pause when the video container scrolls out of view
      const container = iframe.closest(".video-container");
      if (container) {
        new IntersectionObserver(
          ([entry]) => { if (!entry.isIntersecting) pauseVideo(); },
          { threshold: 0 }
        ).observe(container);
      }

      // Pause when the mobile menu opens
      const menuToggle = document.querySelector<HTMLInputElement>(
        "#site-header-burger-toggle"
      );
      menuToggle?.addEventListener("change", () => {
        if (menuToggle.checked) pauseVideo();
      });

      // Pause when the tab loses focus
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) pauseVideo();
      });
    };

    const lazyLoadYouTube = () => {
      if (loaded) return;
      loaded = true;
      const iframes = document.querySelectorAll<HTMLIFrameElement>(
        ".embed-facade iframe[data-src]",
      );
      iframes.forEach((iframe) => {
        iframe.src = iframe.getAttribute("data-src")!;
        iframe.removeAttribute("data-src");
        initYTPlayer(iframe);
      });
    };

    document.addEventListener("scroll", lazyLoadYouTube, { once: true });
    document.addEventListener("click", lazyLoadYouTube, { once: true });
    document.addEventListener("mousemove", lazyLoadYouTube, { once: true });
    document.addEventListener("touchstart", lazyLoadYouTube, { once: true });
    document.addEventListener("touchmove", lazyLoadYouTube, { once: true });
  });
</script>
