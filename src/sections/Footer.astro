---
import Button from "../components/Button.astro";
import Container from "../components/Container.astro";
import TextWipe from "../components/TextWipe.astro";
---

<footer id="matter-container">
  <Container>
    <div class="footer-content">
      <div class="h2">State of the Open Home 2026</div>
      <div class="footer-subtitle">
        An event organized by the Open Home Foundation
      </div>
      <Button
        href="/"
        class="button button--primary button--primary-hover-light"
      >
        Tickets coming soon
      </Button>
    </div>
    <div class="footer-nav">
      <div class="footer-nav-column">
        <div class="footer-nav-title">Home</div>
        <div class="footer-nav-items">
          <TextWipe
            class="footer-nav-item"
            href="/#what-is-state-of-the-open-home"
            >What is State of the Open Home?</TextWipe
          >
          <TextWipe
            class="footer-nav-item"
            href="/#why-were-building-in-the-open"
            >Why we're building in the open</TextWipe
          >
          <TextWipe class="footer-nav-item" href="/#be-part-of-the-conversation"
            >Be part of the conversation</TextWipe
          >
        </div>
      </div>
      <div class="footer-nav-column">
        <div class="footer-nav-title">Social</div>
        <div class="footer-nav-items">
          <TextWipe
            class="footer-nav-item"
            target="_blank"
            href="https://fosstodon.org/@openhomefoundation">Mastodon</TextWipe
          >
          <TextWipe
            class="footer-nav-item"
            target="_blank"
            href="https://bsky.app/profile/openhomefoundation.org"
            >Bluesky</TextWipe
          >
          <TextWipe
            class="footer-nav-item"
            target="_blank"
            href="https://www.instagram.com/openhomefoundation/"
            >Instagram</TextWipe
          >
          <TextWipe
            class="footer-nav-item"
            target="_blank"
            href="https://www.facebook.com/p/Open-Home-Foundation-61558575472603/"
            >Facebook</TextWipe
          >
        </div>
      </div>
      <div class="footer-nav-column">
        <div class="footer-extra">
          <TextWipe href="#">Help & support</TextWipe>
          <span>Copyright @ Open Home Foundation</span>
        </div>
      </div>
    </div>
  </Container>
</footer>

<style lang="scss">
  @use "../styles/mixins/breakpoint.scss" as *;

  footer {
    background-color: var(--ohf-dark-blue);
    //height: 580px;
    position: relative;
    display: flex;
    isolation: isolate;
    padding: 40px 0 120px 0;
    transition: min-height 0.3s ease;
    user-select: none;

    @include bp(desktop) {
      padding: 80px 0 200px 0;
    }

    // Mobile game mode - expand to fill viewport minus header
    &:global(.game-mode) {
      @media (max-width: 767px) {
        min-height: calc(100vh - var(--header-height));
        min-height: calc(100dvh - var(--header-height));
        padding-bottom: 0;
        flex-direction: column;
      }
    }

    :global(canvas) {
      z-index: -1;
    }
    :global(.container) {
      gap: 40px 96px;
    }

    .footer-content {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      max-width: 400px;

      :global(.button) {
        margin-top: 2rem;
      }

      .h2 {
        text-align: left;
      }
    }
    .footer-extra {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-top: -4px;

      :global(.text-wipe) {
        font-weight: 500;
      }

      span {
        font-size: 12px;
      }
    }

    .footer-nav {
      display: flex;
      gap: 20px 60px;
      flex-grow: 1;
      justify-content: space-between;
      flex-direction: column;

      @include bp(tablet) {
        flex-direction: row;
      }

      &-column {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      &-title {
        font-family: var(--typography-heading-font-family);
        font-size: 12px;
        text-transform: uppercase;
      }

      &-items {
        display: flex;
        flex-direction: column;
        gap: 8px;

        :global(.footer-nav-item) {
          color: #a2aab6;
          text-decoration: none;
        }

        :global(.text-wipe) {
          font-size: 12px;
        }
      }
    }
  }
</style>
