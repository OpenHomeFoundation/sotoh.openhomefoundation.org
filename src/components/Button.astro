---
const { class: className = "", href = "/error" } = Astro.props;
---

<a class={className} href={href}><slot /></a>

<style lang="scss" is:global>
  .button {
    color: var(--text-on-dark);
    padding: 12px 24px;
    border-radius: 40px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-family: var(--typography-heading-font-family);
    font-weight: var(--typography-heading-font-weight);
    font-size: 0.75rem;

    &--hollow {
      border: 2px solid var(--sotoh-yellow);
    }

    &--primary {
      background-color: var(--sotoh-yellow);
      color: var(--ohf-dark-blue);

      &:hover {
        color: var(--sotoh-yellow);
        background-color: var(--ohf-dark-blue);
      }
    }
  }
</style>
