---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Container from "../components/Container.astro";
import Ticket from "../components/Ticket.astro";
import Footer from "../sections/Footer.astro";
import { tickets } from "../lib/tickets";

const title = "Tickets - State of the Open Home";
const description = "View all ticket designs for State of the Open Home 2026.";
---

<Layout
  bodyClass="page-home"
  includeEventSchema={false}
  title={title}
  description={description}
>
  <Header slot="header" lightMode />
  <section class="block block-tickets">
    <Container containerClass="container--column">
      <h2 class="h2 text-dark text-center">Ticket Designs</h2>

      <div class="tickets-grid">
        {
          tickets.map((ticket) => (
            <div class="ticket-item">
              <Ticket ticketId={ticket.id} />
            </div>
          ))
        }
      </div>
    </Container>
  </section>
  <Footer />
</Layout>

<style>
  .block-tickets {
    padding: 120px 0 60px;
  }

  .tickets-grid {
    display: flex;
    flex-direction: column;
    gap: 48px;
    margin-top: 48px;
  }

  .ticket-item h3 {
    text-align: center;
    margin-bottom: 16px;
    font-size: 1.25rem;
    color: #333;
  }
</style>
